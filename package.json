{
  "name": "sane-av.github.io",
  "version": "1.0.0",
  "description": "GitHub Pages site for sane-av",
  "author": "sane-av",
  "license": "MIT",
  "packageManager": "pnpm@11.5.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/contentSync.js && concurrently \"node scripts/themeGenerator.js --watch\" \"node scripts/jsonGenerator.js && astro dev\"",
    "build": "node scripts/contentSync.js && node scripts/themeGenerator.js && node scripts/jsonGenerator.js && astro build && node scripts/llmsGenerator.js",
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier -w ./src",
    "generate-json": "node scripts/jsonGenerator.js",
    "generate-llms": "node scripts/llmsGenerator.js"
  },
  "dependencies": {
    "@astrojs/mdx": "7.0.0",
    "@astrojs/react": "6.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@digi4care/astro-google-tagmanager": "^2.0.0",
    "@justinribeiro/lite-youtube": "^1.9.0",
    "astro": "7.0.0",
    "astro-auto-import": "^0.5.1",
    "astro-swiper": "^2.7.0",
    "date-fns": "^4.4.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "^10.0.3",
    "glob": "^13.0.6",
    "node-html-parser": "^8.0.3",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwind-bootstrap-grid": "^7.0.0",
    "tailwindcss": "^4.3.1",
    "turndown": "^7.2.4",
    "typescript": "^6.0.3"
  }
}
