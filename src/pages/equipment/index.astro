---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface EquipmentEntry {
  id: string;
  manufacturer: string;
  model: string;
  category: string;
  specs: Record<string, string>;
  tags: string[];
  notes?: string;
}

const files = import.meta.glob<{ default: unknown[] }>('../../data/equipment/*.json', { eager: true });
const allEquipment: EquipmentEntry[] = Object.entries(files)
  .filter(([path]) => !path.endsWith('schema.json'))
  .flatMap(([, f]) => Array.isArray(f.default) ? f.default : []);

const categories = [...new Set(allEquipment.map((e) => e.category))].sort();
const allTags = [...new Set(allEquipment.flatMap((e) => e.tags))].sort();
---

<BaseLayout title="Equipment Database" description="Open community database of AV equipment specifications.">
  <div class="page-header">
    <div class="container">
      <h1>Equipment Database</h1>
      <p>
        An open, community-maintained database of AV equipment specs.
        All data is CC BY-NC 4.0 - use it in your tools, reports, and designs.
      </p>
      <div class="mt-1">
        <a href="https://github.com/sane-av/sane-av.github.io/issues/new?template=content_submission.yml&title=[Equipment]+New+entry" target="_blank" rel="noopener" class="btn btn-primary btn-small">
          Submit Equipment Data →
        </a>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="equipment-filter">
        <input type="search" id="eq-search" placeholder="Search manufacturer, model, or spec…" aria-label="Search equipment" />
        <select id="eq-cat" aria-label="Filter by category">
          <option value="">All categories</option>
          {categories.map((c) => <option value={c}>{c}</option>)}
        </select>
      </div>

      {allTags.length > 0 && (
        <div class="tag-bar mb-1" id="tag-bar">
          <span class="label-heading">Categories:</span>
          {allTags.map((tag) => (
            <button type="button" class="tag filter-tag" data-tag={tag}>{tag}</button>
          ))}
          <button class="tag-clear" id="tag-clear">Clear all</button>
        </div>
      )}

      <p id="eq-count" class="text-muted mb-1">
        {allEquipment.length} entries
      </p>

      <div class="table-wrapper">
        <table id="eq-table">
          <thead>
            <tr>
              <th>Manufacturer</th>
              <th>Model</th>
              <th>Category</th>
              <th>Key Specs</th>
              <th>Tags</th>
            </tr>
          </thead>
          <tbody>
            {allEquipment.map((item) => (
              <tr data-cat={item.category} data-search={`${item.manufacturer} ${item.model} ${item.tags.join(' ')} ${Object.values(item.specs).join(' ')}`.toLowerCase()} data-tags={item.tags.join(',')}>
                <td><strong>{item.manufacturer}</strong></td>
                <td>{item.model}</td>
                <td><span class="tag">{item.category}</span></td>
                <td>
                  {Object.entries(item.specs).slice(0, 3).map(([k, v]) => (
                    <div class="text-small"><span class="text-muted">{k}:</span> {v}</div>
                  ))}
                </td>
                <td>
                  <div class="card-tags">
                    {item.tags.map((t) => <button type="button" class="tag filter-tag" data-tag={t}>{t}</button>)}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const search = document.getElementById('eq-search') as HTMLInputElement;
  const catSelect = document.getElementById('eq-cat') as HTMLSelectElement;
  const tagButtons = document.querySelectorAll<HTMLButtonElement>('.filter-tag');
  const rows = document.querySelectorAll<HTMLTableRowElement>('#eq-table tbody tr');
  const countEl = document.getElementById('eq-count')!;
  const clearBtn = document.getElementById('tag-clear')!;

  let activeTag = '';

  function filter() {
    const query = search.value.toLowerCase();
    const category = catSelect.value;
    let visible = 0;
    tagButtons.forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.tag === activeTag);
    });
    rows.forEach((row) => {
      const matchSearch = !query || row.dataset.search?.includes(query);
      const matchCategory = !category || row.dataset.cat === category;
      const rowTags = (row.dataset.tags || '').split(',');
      const matchTag = !activeTag || rowTags.includes(activeTag);
      const show = matchSearch && matchCategory && matchTag;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    countEl.textContent = `${visible} entries`;
    clearBtn.classList.toggle('visible', !!activeTag);
  }

  search.addEventListener('input', filter);
  catSelect.addEventListener('change', filter);

  tagButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;
      activeTag = activeTag === tag ? '' : tag;
      filter();
    });
  });

  clearBtn.addEventListener('click', () => {
    activeTag = '';
    filter();
  });

  const params = new URLSearchParams(window.location.search);
  const urlTag = params.get('tag');
  if (urlTag) {
    activeTag = urlTag;
    filter();
  }
</script>
