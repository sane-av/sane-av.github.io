---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDateShort } from '../lib/date';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const standards = (await getCollection('standards', ({ data }) => data.status === 'published'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-layout">
        <img
          class="hero-image"
          src="/sanebrain.png"
          alt="SANE AV brain icon"
          width="260"
          height="260"
        />
        <div class="hero-body">
          <h1>Open Source AV Standards<br />for the Modern World</h1>
          <p>
            SANE is building free, open, and transparent standards for building professional audiovisual systems. No membership fees. No paywalls. No gatekeeping.
          </p>
          <p>
            Are your AV systems SANE?
          </p>
          <div class="hero-actions">
            <a href="/standards" class="btn btn-primary">Browse Standards</a>
            <a href="/rfc" class="btn btn-outline">Propose a Standard</a>
            <a href="https://github.com/sane-av/sane-av.github.io" target="_blank" rel="noopener" class="btn btn-outline">
              GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why SANE? -->
  <section class="section">
    <div class="container">
      <div class="value-grid">
        {[
          { heading: 'Free & Open', body: 'Every standard, document, and dataset is freely available under CC BY-NC 4.0. No paywalls, ever.', icon: '/newspaper-open.svg' },
          { heading: 'Community Driven', body: 'Standards are proposed and refined through an open RFC process. Anyone can contribute.', icon: '/population-globe.svg' },
          { heading: 'Practical First', body: 'Built by working AV professionals for real-world deployment. Theory informed by practice.', icon: '/wisdom.svg' },
          { heading: 'Version Controlled', body: 'Every change is tracked in Git. Audit the full history of any standard or data entry.', icon: '/code-branch.svg' },
        ].map(({ icon, heading, body }) => (
          <div class="card">
            <div class="value-icon">
              <img src={icon} alt="" width="28" height="28" />
            </div>
            <h3>{heading}</h3>
            <p>{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Standards -->
  {standards.length > 0 && (
    <section class="section section-elevated">
      <div class="container">
        <h2 class="section-title">Latest Standards</h2>
        <p class="section-sub">Published SANE standards, free to use and implement.</p>
        <div class="card-grid">
          {standards.map((std) => (
            <div class="card">
              <div class="card-meta">
                <span class={`status-badge status-${std.data.status}`}>{std.data.status}</span>
                <span>{std.data.saneId}</span>
                <span>v{std.data.version}</span>
              </div>
              <h3><a href={`/standards/${std.id}`}>{std.data.title}</a></h3>
              <p>{std.data.description}</p>
              <div class="card-tags">
                {std.data.tags.slice(0, 3).map((tag) => (
                  <a href={`/standards/?tag=${tag}`} class="tag tag-link">{tag}</a>
                ))}
              </div>
            </div>
          ))}
        </div>
        <p class="mt-2"><a href="/standards" class="btn btn-teal">All Standards →</a></p>
      </div>
    </section>
  )}

  <!-- Latest Blog Posts -->
  {posts.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">From the Blog</h2>
        <p class="section-sub">Perspectives, announcements, and deep dives from the SANE community.</p>
        <div class="card-grid">
          {posts.map((post) => (
            <div class="card">
              <div class="card-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDateShort(post.data.pubDate)}
                </time>
                <span>{post.data.author}</span>
              </div>
              <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              <div class="card-tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <a href={`/blog/?tag=${tag}`} class="tag tag-link">{tag}</a>
                ))}
              </div>
            </div>
          ))}
        </div>
        <p class="mt-2"><a href="/blog" class="btn btn-teal">All Posts →</a></p>
      </div>
    </section>
  )}

  <!-- Sponsors -->
  <section class="section section-elevated section-centered">
    <div class="container">
      <h2 class="section-title">Sponsors</h2>
      <p class="section-sub">Support SANE's mission to build free, open AV standards for the professional community.</p>
      <div class="sponsor-logos">
        <img src="/Sponsor_IB_Logo.svg" alt="Sponsor logo" width="240" />
      </div>
      <p class="mt-2">
        <a href="https://github.com/sponsors/sane-av" target="_blank" rel="noopener" class="btn btn-primary btn-small">
          Become a Sponsor →
        </a>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-cta">
    <div class="container">
      <h2>Ready to Contribute?</h2>
      <p class="cta-text">
        SANE is built by the community. Submit an RFC, improve documentation,
        add equipment data, or just spread the word.
      </p>
      <div class="cta-actions">
        <a href="/contributing" class="btn btn-primary">Contribution Guide</a>
        <a href="/rfc" class="btn btn-outline">Open an RFC</a>
      </div>
    </div>
  </section>
</BaseLayout>

