---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDateShort } from '../lib/date';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const standards = (await getCollection('standards', ({ data }) => data.status === 'published'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-layout">
        <img
          class="hero-image"
          src="/sanebrain.png"
          alt="SANE AV brain icon"
          width="260"
          height="260"
        />
        <div class="hero-body">
          <h1>Open Source AV Standards<br />for the Modern World</h1>
          <p>
            SANE is building free, open, and transparent standards for building professional audiovisual systems. No membership fees. No paywalls. No gatekeeping.
          </p>
          <p>
            Are your AV systems SANE?
          </p>
          <div class="hero-actions">
            <a href="/standards" class="btn btn-primary">Browse Standards</a>
            <a href="/rfc" class="btn btn-outline">Propose a Standard</a>
            <a href="https://github.com/sane-av/sane-av.github.io" target="_blank" rel="noopener" class="btn btn-outline">
              GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why SANE? -->
  <section class="section">
    <div class="container">
      <div class="value-grid">
        {[
          { 
            heading: 'Free & Open', 
            body: 'Every standard, document, and dataset is freely available under CC BY-NC 4.0. No paywalls, ever.',
            icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/><path d="M8 7h6"/><path d="M8 11h8"/><path d="M8 15h5"/></svg>`
          },
          { 
            heading: 'Community Driven', 
            body: 'Standards are proposed and refined through an open RFC process. Anyone can contribute.',
            icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="3"/><circle cx="15" cy="7" r="3"/><path d="M6 13.5V14a3 3 0 003 3v0a3 3 0 003-3v-.5"/><path d="M12 14a3 3 0 013-3v0a3 3 0 013 3v.5"/><path d="M9 17v0a3 3 0 006 0v0"/><path d="M6 21h12"/></svg>`
          },
          { 
            heading: 'Practical First', 
            body: 'Built by working AV professionals for real-world deployment. Theory informed by practice.',
            icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`
          },
          { 
            heading: 'Version Controlled', 
            body: 'Every change is tracked in Git. Audit the full history of any standard or data entry.',
            icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="18" r="2"/><path d="M6 8v8"/><path d="M18 16v-2a4 4 0 00-4-4h-4"/><path d="M9 8L6 5 9 2"/></svg>`
          },
        ].map(({ icon, heading, body }) => (
          <div class="card">
            <span class="value-icon" set:html={icon} />
              <h3>{heading}</h3>
            <p>{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Standards -->
  {standards.length > 0 && (
    <section class="section section-elevated">
      <div class="container">
        <h2 class="section-title">Latest Standards</h2>
        <p class="section-sub">Published SANE standards, free to use and implement.</p>
        <div class="card-grid">
          {standards.map((std) => (
            <div class="card">
              <div class="card-meta">
                <span class={`status-badge status-${std.data.status}`}>{std.data.status}</span>
                <span>{std.data.saneId}</span>
                <span>v{std.data.version}</span>
              </div>
              <h3><a href={`/standards/${std.id}`}>{std.data.title}</a></h3>
              <p>{std.data.description}</p>
              <div class="card-tags">
                {std.data.tags.slice(0, 3).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
        <p class="mt-2"><a href="/standards" class="btn btn-teal">All Standards →</a></p>
      </div>
    </section>
  )}

  <!-- Latest Blog Posts -->
  {posts.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">From the Blog</h2>
        <p class="section-sub">Perspectives, announcements, and deep dives from the SANE community.</p>
        <div class="card-grid">
          {posts.map((post) => (
            <div class="card">
              <div class="card-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDateShort(post.data.pubDate)}
                </time>
                <span>{post.data.author}</span>
              </div>
              <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              <div class="card-tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
        <p class="mt-2"><a href="/blog" class="btn btn-teal">All Posts →</a></p>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section section-cta">
    <div class="container">
      <h2>Ready to Contribute?</h2>
      <p class="cta-text">
        SANE is built by the community. Submit an RFC, improve documentation,
        add equipment data, or just spread the word.
      </p>
      <div class="cta-actions">
        <a href="/contributing" class="btn btn-primary">Contribution Guide</a>
        <a href="/rfc" class="btn btn-outline">Open an RFC</a>
      </div>
    </div>
  </section>
</BaseLayout>

