---
import Base from "@/layouts/Base.astro";
import ImageMod from "@/layouts/components/ImageMod.astro";
import dateFormat from "@/lib/utils/dateFormat";
import { getCollection } from "astro:content";
import { statusColors } from "@/lib/statusColors";

const recentPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0))
  .slice(0, 3);

const recentStandards = (await getCollection("standards", ({ data }) => data.status === "published"))
  .sort((a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0))
  .slice(0, 3);

const recentWhitepapers = (await getCollection("whitepapers", ({ data }) => !data.draft))
  .sort((a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0))
  .slice(0, 3);
---

<Base title="SANE - Society for AV Norms & Engineering" description="Open source AV standards, data, and tools for the professional audiovisual industry.">
  <!-- Hero -->
  <section class="section-sm py-10 xl:py-14">
    <div class="container">
      <div class="row items-center justify-center" style="--bs-gutter-x: 0.5rem">
        <div class="lg:col-4 mb-10 text-center lg:text-left lg:mb-0">
            <ImageMod
              src="/images/sanebrain.png"
              alt="SANE AV brain icon"
              width={260}
              height={275}
              class="mx-auto lg:mx-0 hero-glow"
              format="webp"
              loading="eager"
              decoding="sync"
            />
        </div>
        <div class="lg:col-6 text-center lg:text-left">
          <h1 class="mb-6">Open Source AV Standards<br />for the Modern World</h1>
          <p class="mb-4 text-text-light dark:text-darkmode-text-light text-pretty">
            SANE is building free, open, and transparent standards for building professional audiovisual systems. No membership fees. No paywalls. No gatekeeping.
          </p>
          <p class="mb-8 text-text-light dark:text-darkmode-text-light text-pretty">
            Are your AV systems SANE?
          </p>
          <div class="flex flex-col gap-3 sm:flex-row sm:justify-center lg:justify-start">
            <a href="/standards" class="btn btn-primary">Browse Standards</a>
            <a href="/contributing" class="btn btn-outline-primary">Propose a Standard</a>
            <a href="https://github.com/sane-av/sane-av.github.io" target="_blank" rel="noopener" class="btn btn-outline-primary">GitHub</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why SANE? -->
  <section class="section-sm py-10 xl:py-14 bg-gradient">
    <div class="container">
      <div class="row justify-center">
        {[
          { icon: "/images/newspaper-open.svg", heading: "Free & Open", body: "Every standard, document, and dataset is freely available under CC BY-SA 4.0. No paywalls, ever." },
          { icon: "/images/population-globe.svg", heading: "Community Driven", body: "Standards are proposed and refined through an open RFC process. Anyone can contribute." },
          { icon: "/images/wisdom.svg", heading: "Practical First", body: "Built by working AV professionals for real-world deployment. Theory informed by practice." },
          { icon: "/images/code-branch.svg", heading: "Version Controlled", body: "Every change is tracked in Git. Audit the full history of any standard or data entry." },
        ].map(({ icon, heading, body }) => (
          <div class="md:col-6 lg:col-3 mb-8">
            <div class="h-full rounded-lg border border-border p-6 text-center dark:border-darkmode-border">
              <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 dark:bg-darkmode-primary/20">
                <ImageMod src={icon} alt={heading} width={32} height={32} format="svg" />
              </div>
              <h3 class="mb-3 h5">{heading}</h3>
              <p class="text-text-light dark:text-darkmode-text-light">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section id="newsletter" class="section-sm py-10 xl:py-14 scroll-mt-24">
    <div class="container text-center">
      <h2 class="mb-2">Stay Updated</h2>
      <p class="mb-6 text-text-light dark:text-darkmode-text-light">Get new standards, blog posts, and tools delivered to your inbox.</p>
      <form
        action="https://app.kit.com/forms/9585155/subscriptions"
        class="mx-auto flex max-w-md gap-2"
        method="post"
        data-sv-form="9585155"
        data-uid="b3f2fa3c84"
        data-format="inline"
        data-version="5"
      >
        <input class="form-input flex-1 !py-2" name="email_address" type="email" placeholder="you@example.com" required aria-label="Email Address" />
        <button data-element="submit" class="btn btn-primary">Subscribe</button>
      </form>
      <p class="mt-3 text-sm text-text-light dark:text-darkmode-text-light">No spam. Unsubscribe anytime.</p>
    </div>
    <script src="https://f.convertkit.com/ckjs/ck.5.js" async></script>
  </section>

  <!-- Latest Standards -->
  {recentStandards.length > 0 && (
    <section class="section-sm py-10 xl:py-14 bg-gradient">
      <div class="container">
        <h2 class="mb-2 text-center">Latest Standards</h2>
        <p class="mb-10 text-center text-text-light dark:text-darkmode-text-light">Published SANE standards, free to use and implement.</p>
        <div class="row justify-center">
          {recentStandards.map((std) => (
            <div class="md:col-6 lg:col-4 mb-8">
              <div class="h-full flex flex-col rounded-lg border border-border p-6 dark:border-darkmode-border">
                <div class="mb-3 flex gap-2 text-sm">
                  <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${statusColors[std.data.status] || ""}`}>
                    {std.data.status}
                  </span>
                  <span class="text-text-light dark:text-darkmode-text-light">{std.data.saneId}</span>
                  <span class="text-text-light dark:text-darkmode-text-light">v{std.data.version}</span>
                </div>
                <h3 class="mb-2 h5"><a href={`/standards/${std.id}`}>{std.data.title}</a></h3>
                <p class="grow mb-4 line-clamp-4 overflow-hidden text-text-light dark:text-darkmode-text-light">{std.data.description}</p>
                <div class="flex flex-wrap gap-1 mt-auto">
                  {std.data.tags.slice(0, 3).map((tag: string) => (
                    <a href={`/standards/?tag=${tag}`} class="rounded bg-light px-2 py-0.5 text-xs underline decoration-text-light/50 underline-offset-2 hover:bg-primary hover:text-white dark:bg-darkmode-body dark:decoration-darkmode-primary/40 dark:hover:bg-darkmode-primary dark:hover:text-dark">
                      #{tag}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
        <p class="text-center">
          <a href="/standards" class="btn btn-outline-primary">All Standards &rarr;</a>
        </p>
      </div>
    </section>
  )}

  <!-- Latest Whitepapers -->
  {recentWhitepapers.length > 0 && (
    <section class="section-sm py-10 xl:py-14">
      <div class="container">
        <h2 class="mb-2 text-center">Latest Whitepapers</h2>
        <p class="mb-10 text-center text-text-light dark:text-darkmode-text-light">Technical deep dives and analysis by SANE editors.</p>
        <div class="row justify-center">
          {recentWhitepapers.map((wp) => (
            <div class="md:col-6 lg:col-4 mb-8">
              <div class="h-full flex flex-col rounded-lg border border-border p-6 dark:border-darkmode-border">
                <div class="mb-3 flex gap-2 text-sm text-text-light dark:text-darkmode-text-light">
                  <time datetime={wp.data.pubDate.toISOString()}>{dateFormat(wp.data.pubDate)}</time>
                  <span>{(wp.data.authors ?? [wp.data.author]).join(", ")}</span>
                </div>
                <h3 class="mb-2 h5"><a href={`/whitepapers/${wp.id}`}>{wp.data.title}</a></h3>
                <p class="grow mb-4 line-clamp-4 overflow-hidden text-text-light dark:text-darkmode-text-light">{wp.data.description}</p>
                <div class="flex flex-wrap gap-1 mt-auto">
                  {wp.data.tags.slice(0, 3).map((tag: string) => (
                    <a href={`/whitepapers/?tag=${tag}`} class="rounded bg-light px-2 py-0.5 text-xs underline decoration-text-light/50 underline-offset-2 hover:bg-primary hover:text-white dark:bg-darkmode-body dark:decoration-darkmode-primary/40 dark:hover:bg-darkmode-primary dark:hover:text-dark">
                      #{tag}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
        <p class="text-center">
          <a href="/whitepapers" class="btn btn-outline-primary">All Whitepapers &rarr;</a>
        </p>
      </div>
    </section>
  )}

  <!-- Latest Blog Posts -->
  {recentPosts.length > 0 && (
    <section class="section-sm py-10 xl:py-14 bg-gradient">
      <div class="container">
        <h2 class="mb-2 text-center">From the Blog</h2>
        <p class="mb-10 text-center text-text-light dark:text-darkmode-text-light">Perspectives, announcements, and deep dives from the SANE community.</p>
        <div class="row justify-center">
          {recentPosts.map((post) => (
            <div class="md:col-6 lg:col-4 mb-8">
              <div class="h-full flex flex-col rounded-lg border border-border p-6 dark:border-darkmode-border">
                <div class="mb-3 flex gap-2 text-sm text-text-light dark:text-darkmode-text-light">
                  <time datetime={post.data.pubDate.toISOString()}>{dateFormat(post.data.pubDate)}</time>
                  <span>{(post.data.authors ?? [post.data.author]).join(", ")}</span>
                </div>
                <h3 class="mb-2 h5"><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
                <p class="grow mb-4 line-clamp-4 overflow-hidden text-text-light dark:text-darkmode-text-light">{post.data.description}</p>
                <div class="flex flex-wrap gap-1 mt-auto">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <a href={`/blog/?tag=${tag}`} class="rounded bg-light px-2 py-0.5 text-xs underline decoration-text-light/50 underline-offset-2 hover:bg-primary hover:text-white dark:bg-darkmode-body dark:decoration-darkmode-primary/40 dark:hover:bg-darkmode-primary dark:hover:text-dark">
                      #{tag}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
        <p class="text-center">
          <a href="/blog" class="btn btn-outline-primary">All Posts &rarr;</a>
        </p>
      </div>
    </section>
  )}


  <!-- Sponsors -->
  <section class="section-sm py-10 xl:py-14">
    <div class="container text-center">
      <h2 class="mb-2">Sponsors</h2>
      <p class="mb-6 text-text-light dark:text-darkmode-text-light">Support SANE's mission to build free, open AV standards for the professional community.</p>
      <ImageMod src="/images/Sponsor_IB_Logo.svg" alt="Sponsor logo" width={240} height={64} class="mx-auto mb-6" format="svg" />
      <a href="https://github.com/sponsors/sane-av" target="_blank" rel="noopener" class="btn btn-outline-primary">
        Become a Sponsor &rarr;
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm py-10 xl:py-14 bg-gradient">
    <div class="container text-center">
      <h2 class="mb-2">Ready to Contribute?</h2>
      <p class="mb-6 text-text-light dark:text-darkmode-text-light">SANE is built by the community. Submit an RFC, improve documentation, add equipment data, or just spread the word.</p>
      <div class="flex justify-center gap-3">
        <a href="/contributing" class="btn btn-primary">Contribution Guide</a>
        <a href="/contributing" class="btn btn-outline-primary">Open an RFC</a>
      </div>
    </div>
  </section>
</Base>
