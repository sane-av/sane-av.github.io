---
import Base from "@/layouts/Base.astro";
---

<Base title="SPL / dB Calculator" description="Convert between dBu, dBV, dBFS, dB SPL and calculate voltage and power ratios.">
  <section class="section-sm">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-8">
          <h1 class="mb-2">SPL / dB Calculator</h1>
          <p class="mb-8 text-text-light dark:text-darkmode-text-light">Convert between dBu, dBV, voltage, and calculate level differences.</p>

          <!-- Level Converter -->
          <div class="mb-8 rounded-lg border border-border p-6 dark:border-darkmode-border">
            <h2 class="h5 mb-4">Level Converter</h2>
            <div class="row">
              <div class="md:col-6 mb-4">
                <label for="inp-dbu" class="form-label">dBu</label>
                <input id="inp-dbu" type="number" step="0.1" placeholder="e.g. 4" class="form-input w-full" />
              </div>
              <div class="md:col-6 mb-4">
                <label for="inp-dbv" class="form-label">dBV</label>
                <input id="inp-dbv" type="number" step="0.1" placeholder="e.g. 1.78" class="form-input w-full" />
              </div>
              <div class="md:col-6 mb-4">
                <label for="inp-v" class="form-label">Voltage (V RMS)</label>
                <input id="inp-v" type="number" step="0.001" placeholder="e.g. 1.228" class="form-input w-full" />
              </div>
              <div class="md:col-6 mb-4">
                <label for="inp-mv" class="form-label">Voltage (mV RMS)</label>
                <input id="inp-mv" type="number" step="0.1" placeholder="e.g. 1228" class="form-input w-full" />
              </div>
            </div>
            <div id="level-result" class="hidden rounded-lg bg-primary/10 p-4 dark:bg-darkmode-primary/20">
              <span class="text-sm text-text-light dark:text-darkmode-text-light">Result</span>
              <div id="level-result-text" class="mt-1 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark"></div>
            </div>
          </div>

          <!-- Ratio Calculator -->
          <div class="mb-8 rounded-lg border border-border p-6 dark:border-darkmode-border">
            <h2 class="h5 mb-4">Level Difference</h2>
            <div class="row">
              <div class="md:col-6 mb-4">
                <label for="ratio-v1" class="form-label">Voltage 1 (V)</label>
                <input id="ratio-v1" type="number" step="0.001" placeholder="e.g. 1.228" class="form-input w-full" />
              </div>
              <div class="md:col-6 mb-4">
                <label for="ratio-v2" class="form-label">Voltage 2 (V)</label>
                <input id="ratio-v2" type="number" step="0.001" placeholder="e.g. 0.775" class="form-input w-full" />
              </div>
            </div>
            <div id="ratio-result" class="hidden rounded-lg bg-primary/10 p-4 dark:bg-darkmode-primary/20">
              <span class="text-sm text-text-light dark:text-darkmode-text-light">Difference</span>
              <div id="ratio-result-text" class="mt-1 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark"></div>
            </div>
          </div>

          <!-- Reference Table -->
          <div class="overflow-x-auto rounded-lg border border-border p-6 dark:border-darkmode-border">
            <h2 class="h5 mb-4">Common Reference Levels</h2>
            <table class="w-full text-left text-sm">
              <thead><tr class="border-b border-border dark:border-darkmode-border"><th class="px-2 py-2">Level</th><th class="px-2 py-2">dBu</th><th class="px-2 py-2">dBV</th><th class="px-2 py-2">V RMS</th><th class="px-2 py-2">Use</th></tr></thead>
              <tbody>
                <tr class="border-b border-border dark:border-darkmode-border"><td class="px-2 py-2">+4 dBu</td><td class="px-2 py-2">+4.0</td><td class="px-2 py-2">+2.22</td><td class="px-2 py-2">1.228</td><td class="px-2 py-2">Pro audio nominal</td></tr>
                <tr class="border-b border-border dark:border-darkmode-border"><td class="px-2 py-2">0 dBV</td><td class="px-2 py-2">+2.22</td><td class="px-2 py-2">0</td><td class="px-2 py-2">1.000</td><td class="px-2 py-2">Consumer reference</td></tr>
                <tr class="border-b border-border dark:border-darkmode-border"><td class="px-2 py-2">0 dBu</td><td class="px-2 py-2">0</td><td class="px-2 py-2">−2.22</td><td class="px-2 py-2">0.775</td><td class="px-2 py-2">0 dBu reference (600 Ω)</td></tr>
                <tr class="border-b border-border dark:border-darkmode-border"><td class="px-2 py-2">−10 dBV</td><td class="px-2 py-2">−7.78</td><td class="px-2 py-2">−10</td><td class="px-2 py-2">0.316</td><td class="px-2 py-2">Consumer nominal</td></tr>
                <tr><td class="px-2 py-2">Mic level</td><td class="px-2 py-2">−60 to −40</td><td class="px-2 py-2">N/A</td><td class="px-2 py-2">1–10 mV</td><td class="px-2 py-2">Microphone output</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { initSplCalculator } from "@/lib/tools/spl-calculator";
  initSplCalculator();
</script>
