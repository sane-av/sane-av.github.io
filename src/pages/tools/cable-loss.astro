---
import Base from "@/layouts/Base.astro";
---

<Base title="Cable Loss Calculator" description="Estimate signal loss in coax and twisted-pair AV cables by cable type, length, and frequency.">
  <section class="section-sm">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-8">
          <h1 class="mb-2">Cable Loss Calculator</h1>
          <p class="mb-8 text-text-light dark:text-darkmode-text-light">Estimate attenuation in common AV cables. Loss scales roughly with the square root of frequency.</p>

          <div class="mb-8 rounded-lg border border-border p-6 dark:border-darkmode-border">
            <div class="mb-4">
              <label for="cl-cable" class="form-label">Cable type</label>
              <select id="cl-cable" class="form-input w-full">
                <option value="12.8">Belden 1694A RG-6 (12.8 dB/100m @ 1 GHz)</option>
                <option value="14.0">RG-6 generic (14.0 dB/100m @ 1 GHz)</option>
                <option value="20.0">RG-59 (20.0 dB/100m @ 1 GHz)</option>
                <option value="8.0">RG-11 (8.0 dB/100m @ 1 GHz)</option>
                <option value="22.0">Cat5e UTP (22.0 dB/100m @ 100 MHz)</option>
                <option value="19.0">Cat6 UTP (19.0 dB/100m @ 100 MHz)</option>
                <option value="0.5">XLR analog audio (0.5 dB/100m @ 20 kHz)</option>
              </select>
            </div>
            <div class="mb-4">
              <label for="cl-length" class="form-label">Length</label>
              <input id="cl-length" type="number" step="0.1" min="0" placeholder="e.g. 30" class="form-input w-full" />
            </div>
            <div class="mb-4">
              <label for="cl-unit" class="form-label">Unit</label>
              <select id="cl-unit" class="form-input w-full">
                <option value="m">meters</option>
                <option value="ft">feet</option>
              </select>
            </div>
            <div class="mb-4">
              <label for="cl-freq" class="form-label">Frequency</label>
              <div class="flex gap-2">
                <input id="cl-freq" type="number" step="0.1" min="0" placeholder="e.g. 1000" class="form-input flex-1" />
                <select id="cl-freq-unit" class="form-input w-24">
                  <option value="MHz">MHz</option>
                  <option value="GHz">GHz</option>
                  <option value="kHz">kHz</option>
                </select>
              </div>
              <p class="mt-1 text-xs text-text-light dark:text-darkmode-text-light">
                Reference frequency is 1 GHz for coax, 100 MHz for Cat5e/Cat6, 20 kHz for XLR.
              </p>
            </div>
            <button id="cl-calc" class="btn btn-primary w-full">Calculate</button>

            <div id="cl-result" class="mt-4 hidden rounded-lg bg-primary/10 p-4 dark:bg-darkmode-primary/20">
              <span class="text-sm text-text-light dark:text-darkmode-text-light">Estimated Loss</span>
              <div id="cl-result-value" class="mt-1 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark"></div>
              <div id="cl-result-sub" class="mt-1 text-sm text-text-light dark:text-darkmode-text-light"></div>
            </div>
            <div id="cl-error" class="mt-4 hidden rounded-lg bg-red-100 p-4 text-red-800 dark:bg-red-900/40 dark:text-red-300"></div>
          </div>

          <div class="rounded-lg border border-border p-6 dark:border-darkmode-border">
            <h2 class="h5 mb-2">How to use</h2>
            <p class="text-text-light dark:text-darkmode-text-light">Cable loss increases with length and frequency. For digital AV signals, total loss should stay within the receiver's input sensitivity margin. When in doubt, measure with a cable tester or signal analyzer.</p>
            <p class="mt-3 text-sm text-text-light dark:text-darkmode-text-light">Values are approximate. Manufacturer datasheets are authoritative.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { initCableLossCalculator } from "@/lib/tools/cable-loss";
  initCableLossCalculator();
</script>
