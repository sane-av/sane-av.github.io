---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  {
    href: '/tools/spl-calculator',
    icon: '🔊',
    title: 'SPL / dB Calculator',
    description: 'Convert between dBu, dBV, dBFS, and acoustic SPL. Calculate voltage and power ratios.',
    tags: ['audio', 'signal levels'],
  },
  {
    href: '/tools/throw-ratio',
    icon: '📽️',
    title: 'Throw Ratio Calculator',
    description: 'Calculate projector throw distance, screen width, or throw ratio from any two known values.',
    tags: ['video', 'projection'],
  },
];

const allTags = [...new Set(tools.flatMap((t) => t.tags))].sort();
---

<BaseLayout title="Tools" description="Free open source AV engineering calculators and tools.">
  <div class="page-header">
    <div class="container">
      <h1>AV Engineering Tools</h1>
      <p>Free, open source calculators for AV system design and engineering.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {allTags.length > 0 && (
        <div class="tag-bar" id="tag-bar">
          <span class="label-heading">Categories:</span>
          {allTags.map((tag) => (
            <button type="button" class="tag filter-tag" data-tag={tag}>{tag}</button>
          ))}
          <button class="tag-clear" id="tag-clear">Clear all</button>
        </div>
      )}

      <p id="tool-count" class="text-muted mb-1">{tools.length} tool{tools.length !== 1 ? 's' : ''}</p>

      <div class="card-grid" id="card-grid">
        {tools.map((tool) => (
          <a href={tool.href} class="card tool-card-link" data-tags={tool.tags.join(',')}>
            <div class="emoji-xl">{tool.icon}</div>
            <h3 class="mt-1">{tool.title}</h3>
            <p>{tool.description}</p>
            <div class="card-tags">
              {tool.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </a>
        ))}
      </div>

      <div class="rfc-box mt-3">
        <h3>Missing a tool?</h3>
        <p>
          Open an issue on GitHub to request a calculator, or submit a PR with your own.
          All tools are client-side JavaScript - no server required.
        </p>
        <p class="mt-1">
          <a href="https://github.com/sane-av/sane-av.github.io/issues/new" target="_blank" rel="noopener" class="btn btn-teal btn-small">
            Request a Tool →
          </a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const tagButtons = document.querySelectorAll<HTMLButtonElement>('.filter-tag');
  const cards = document.querySelectorAll<HTMLDivElement>('#card-grid [data-tags]');
  const countEl = document.getElementById('tool-count')!;
  const clearBtn = document.getElementById('tag-clear')!;
  const totalCount = cards.length;

  let activeTag = '';

  function applyFilters() {
    let visible = 0;
    tagButtons.forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.tag === activeTag);
    });
    cards.forEach((card) => {
      const cardTags = (card.dataset.tags || '').split(',');
      const match = !activeTag || cardTags.includes(activeTag);
      (card as HTMLElement).style.display = match ? '' : 'none';
      if (match) visible++;
    });
    const filtering = !!activeTag;
    countEl.textContent = filtering
      ? `${visible} of ${totalCount} tool${totalCount !== 1 ? 's' : ''}`
      : `${totalCount} tool${totalCount !== 1 ? 's' : ''}`;
    clearBtn.classList.toggle('visible', filtering);
  }

  tagButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;
      activeTag = activeTag === tag ? '' : tag;
      applyFilters();
    });
  });

  clearBtn.addEventListener('click', () => {
    activeTag = '';
    applyFilters();
  });

  const params = new URLSearchParams(window.location.search);
  const urlTag = params.get('tag');
  if (urlTag) {
    activeTag = urlTag;
    applyFilters();
  }
</script>
