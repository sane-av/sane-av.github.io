---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const standards = (await getCollection('standards'))
  .sort((a, b) => a.data.saneId.localeCompare(b.data.saneId));

const statusOrder = { published: 0, review: 1, draft: 2, deprecated: 3 };
const grouped = standards.reduce<Record<string, typeof standards>>((acc, std) => {
  const s = std.data.status;
  if (!acc[s]) acc[s] = [];
  acc[s].push(std);
  return acc;
}, {});

const orderedStatuses = (['published', 'review', 'draft', 'deprecated'] as const)
  .filter((s) => grouped[s]?.length);
---

<BaseLayout title="Standards" description="Free, open AV standards from the SANE community.">
  <div class="page-header">
    <div class="container">
      <h1>SANE Standards</h1>
      <p>Free, open, community-developed standards for professional AV systems.</p>
      <div style="margin-top:1rem">
        <a href="/rfc" class="btn btn-primary" style="font-size:.875rem">
          Propose a Standard via RFC →
        </a>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {standards.length === 0 ? (
        <div class="rfc-box">
          <h3>No standards published yet</h3>
          <p>Be the first to contribute! Open an RFC on GitHub to propose the first SANE standard.</p>
          <p style="margin-top:.75rem">
            <a href="/rfc" class="btn btn-teal" style="font-size:.875rem">Open an RFC →</a>
          </p>
        </div>
      ) : (
        orderedStatuses.map((status) => (
          <div style="margin-bottom:2.5rem">
            <h2 style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.25rem;font-size:1.2rem">
              <span class={`status-badge status-${status}`}>{status}</span>
              <span style="color:var(--color-muted);font-weight:400;font-size:.9rem">
                {grouped[status].length} standard{grouped[status].length !== 1 ? 's' : ''}
              </span>
            </h2>
            <div class="card-grid">
              {grouped[status].map((std) => (
                <div class="card">
                  <div class="card-meta">
                    <span style="font-family:var(--font-mono);font-weight:700;color:var(--color-navy)">{std.data.saneId}</span>
                    <span>v{std.data.version}</span>
                    <time datetime={std.data.pubDate.toISOString()}>
                      {std.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                    </time>
                  </div>
                  <h3><a href={`/standards/${std.id}`}>{std.data.title}</a></h3>
                  <p>{std.data.description}</p>
                  <div class="card-tags">
                    {std.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      )}
    </div>
  </section>
</BaseLayout>
