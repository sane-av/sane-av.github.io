---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { formatDateLong } from '../../lib/date';

export async function getStaticPaths() {
  const standards = await getCollection('standards');
  return standards.map((std) => ({
    params: { slug: std.id },
    props: { std },
  }));
}

const { std } = Astro.props;
const { Content } = await render(std);

const dateStr = formatDateLong(std.data.pubDate);
const updatedStr = std.data.updatedDate ? formatDateLong(std.data.updatedDate) : undefined;
---

<BaseLayout title={`${std.data.saneId}: ${std.data.title}`} description={std.data.description}>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> <span>›</span>
        <a href="/standards">Standards</a> <span>›</span>
        <span>{std.data.saneId}</span>
      </nav>
      <div class="standard-header">
        <span class={`status-badge status-${std.data.status}`}>{std.data.status}</span>
        <span class="sane-id">{std.data.saneId}</span>
        <span class="text-muted">Version {std.data.version}</span>
      </div>
      <h1>{std.data.title}</h1>
      <p>{std.data.description}</p>
    </div>
  </div>

  <section class="section">
    <div class="container content-width">
      <!-- Metadata block -->
      <div class="standard-meta">
        <div class="meta-item">
          <span class="meta-label">Standard ID</span>
          <strong class="sane-id">{std.data.saneId}</strong>
        </div>
        <div class="meta-item">
          <span class="meta-label">Version</span>
          <strong>{std.data.version}</strong>
        </div>
        <div class="meta-item">
          <span class="meta-label">Status</span>
          <span class={`status-badge status-${std.data.status}`}>{std.data.status}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Published</span>
          <span>{dateStr}</span>
        </div>
        {updatedStr && (
          <div class="meta-item">
            <span class="meta-label">Last Updated</span>
            <span>{updatedStr}</span>
          </div>
        )}
        <div class="meta-item">
          <span class="meta-label">Authors</span>
          <span>{std.data.authors.join(', ')}</span>
        </div>
      </div>

      {std.data.tags.length > 0 && (
        <div class="card-tags mb-2">
          {std.data.tags.map((tag) => <a href={`/standards/?tag=${tag}`} class="tag tag-link">{tag}</a>)}
        </div>
      )}

      {std.data.relatedStandards.length > 0 && (
        <div class="rfc-box mb-3">
          <h3>Related Standards</h3>
          <p>{std.data.relatedStandards.join(' · ')}</p>
        </div>
      )}

      <article class="prose">
        <Content />
      </article>

      <hr />
      <p class="text-muted">
        This standard is published under <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener">CC BY-NC 4.0</a>.
        Found an error or want to suggest changes? <a href={`https://github.com/sane-av/sane-av.github.io/issues/new?template=rfc.yml&title=[Amendment+${std.data.saneId}]`} target="_blank" rel="noopener">Open an issue on GitHub</a>.
      </p>
    </div>
  </section>
</BaseLayout>
