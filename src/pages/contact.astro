---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/partials/PageHeader.astro";
---

<Base
  title="Contact"
  description="How to reach the SANE community: GitHub Discussions for questions, Issues for bugs and proposals."
>
  <PageHeader title="Contact" />

  <section class="section-sm">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-8">
          <p class="mb-10 text-center text-lg text-text-light dark:text-darkmode-text-light">
            SANE is an open community project — everything happens in public on GitHub.
            Pick the channel that fits:
          </p>

          <div class="row g-4">
            <div class="mb-6 md:col-6">
              <div class="h-full rounded-lg border border-border p-6 dark:border-darkmode-border">
                <h3 class="mb-2 text-h5">Questions &amp; ideas</h3>
                <p class="mb-4 text-sm text-text-light dark:text-darkmode-text-light">
                  General questions, feedback, and open-ended discussion about standards or the project.
                </p>
                <a href="https://github.com/sane-av/sane-av.github.io/discussions" target="_blank" rel="noopener" class="btn btn-primary btn-sm">GitHub Discussions &rarr;</a>
              </div>
            </div>

            <div class="mb-6 md:col-6">
              <div class="h-full rounded-lg border border-border p-6 dark:border-darkmode-border">
                <h3 class="mb-2 text-h5">Bugs &amp; proposals</h3>
                <p class="mb-4 text-sm text-text-light dark:text-darkmode-text-light">
                  Site issues, content corrections, or formal RFC proposals for new standards.
                </p>
                <a href="https://github.com/sane-av/sane-av.github.io/issues" target="_blank" rel="noopener" class="btn btn-primary btn-sm">GitHub Issues &rarr;</a>
              </div>
            </div>

            <div class="mb-6 md:col-6">
              <div class="h-full rounded-lg border border-border p-6 dark:border-darkmode-border">
                <h3 class="mb-2 text-h5">Contributing</h3>
                <p class="mb-4 text-sm text-text-light dark:text-darkmode-text-light">
                  Want to write, review, or improve standards, glossary terms, or tools? Start here.
                </p>
                <a href="/contributing" class="btn btn-outline-primary btn-sm">Contribution guide &rarr;</a>
              </div>
            </div>

            <div class="mb-6 md:col-6">
              <div class="h-full rounded-lg border border-border p-6 dark:border-darkmode-border">
                <h3 class="mb-2 text-h5">Stay updated</h3>
                <p class="mb-4 text-sm text-text-light dark:text-darkmode-text-light">
                  Occasional project updates by email, or subscribe to the machine-readable feeds.
                </p>
                <a href="/#newsletter" class="btn btn-outline-primary btn-sm">Newsletter &rarr;</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
