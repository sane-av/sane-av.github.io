---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/partials/PageHeader.astro";
---

<Base title="SANE-F Founder Certificate" description="SANE-F Founder Certification certificate.">
  <PageHeader title="Your Certificate" />

  <section class="section-sm">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-10">

          <div id="cert-no-data" class="rounded-lg border border-border p-8 text-center dark:border-darkmode-border hidden">
            <h2 class="mb-4 h4">No certificate data</h2>
            <p class="mb-6 text-text-light dark:text-darkmode-text-light">
              Complete the quiz to earn your certificate.
            </p>
            <a href="/certifications/founder" class="btn btn-primary">Take the Quiz</a>
          </div>

          <div id="cert-display" class="hidden">

            <!-- Congrats -->
            <div class="mb-8 text-center">
              <h2 id="congrats-heading" class="mb-2 h3"></h2>
              <p id="congrats-score" class="text-text-light dark:text-darkmode-text-light"></p>
            </div>

            <!-- Certificate -->
            <div class="mb-10 text-center">
              <div id="cert-svg-wrapper" class="mx-auto inline-block"></div>
              <div class="mt-6">
                <button id="btn-download-pdf" class="btn btn-primary">Download PDF</button>
                <a href="/certifications/founder" class="btn btn-outline-primary ml-3">Retake Quiz</a>
                <a href="/certifications" class="btn btn-outline-primary ml-3">All Certifications</a>
              </div>
            </div>

            <!-- Email Badge -->
            <div class="mb-8 rounded-lg border border-border p-6 dark:border-darkmode-border">
              <h3 class="mb-2 h5">Email Signature Badge</h3>
              <p class="mb-4 text-sm text-text-light dark:text-darkmode-text-light">
                Download this badge to add to your email signature. Available in SVG and PNG at three sizes.
              </p>
              <div id="badge-svg-wrapper" class="mb-6 flex justify-center"></div>
              <div class="flex flex-wrap items-center justify-center gap-2">
                <span class="mr-2 text-sm text-text-light dark:text-darkmode-text-light">Download:</span>
                <button id="btn-badge-svg" class="rounded border border-border px-3 py-1.5 text-sm hover:bg-primary hover:text-white dark:border-darkmode-border dark:hover:bg-darkmode-primary dark:hover:text-text-dark transition-colors">SVG</button>
                <button id="btn-badge-png-lg" class="rounded border border-border px-3 py-1.5 text-sm hover:bg-primary hover:text-white dark:border-darkmode-border dark:hover:bg-darkmode-primary dark:hover:text-text-dark transition-colors">PNG Large</button>
                <button id="btn-badge-png-md" class="rounded border border-border px-3 py-1.5 text-sm hover:bg-primary hover:text-white dark:border-darkmode-border dark:hover:bg-darkmode-primary dark:hover:text-text-dark transition-colors">PNG Medium</button>
                <button id="btn-badge-png-sm" class="rounded border border-border px-3 py-1.5 text-sm hover:bg-primary hover:text-white dark:border-darkmode-border dark:hover:bg-darkmode-primary dark:hover:text-text-dark transition-colors">PNG Small</button>
              </div>
            </div>

          </div>

        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  @media print {
    body * { visibility: hidden; }
    #cert-svg-wrapper, #cert-svg-wrapper * { visibility: visible; }
    #cert-svg-wrapper { position: absolute; left: 0; top: 0; width: 100%; }
    #cert-svg-wrapper svg { max-width: 100%; height: auto; }
    header, footer, nav, .breadcrumbs, button, a, #cert-no-data,
    #cert-display > div:not(#cert-svg-wrapper),
    #cert-display > .flex { display: none !important; }
  }
</style>

<script>
  import { hexToBytes, SIGNING_KEY_HEX } from "@/lib/certification";

  // Re-inits on every navigation (view transitions); guard because the event
  // fires on all pages once this module is loaded.
  function initCertificatePage() {
    const noData = document.getElementById("cert-no-data");
    if (!noData) return;

    const params = new URLSearchParams(window.location.search);
    const name = params.get("name");
    const date = params.get("date");
    const score = params.get("score");
    const total = params.get("total");
    const sig = params.get("sig");
    const uid = Math.random().toString(36).substring(2, 8);

    if (!name || !date || !score || !total || !sig) {
      noData.classList.remove("hidden");
      return;
    }

    verifySig(name, date, score, total, sig).then((valid) => {
      if (!valid) {
        noData.classList.remove("hidden");
        return;
      }

      document.getElementById("cert-display")!.classList.remove("hidden");
      const scoreNum = parseInt(score);
      const totalNum = parseInt(total);
      const percentage = Math.round((scoreNum / totalNum) * 100);
      const safeName = escapeXml(name);
      const safeDate = escapeXml(date);

      document.getElementById("congrats-heading")!.textContent = "Congratulations, " + name + "!";
      document.getElementById("congrats-score")!.textContent = "You earned the SANE-F Founder Certification with a score of " + percentage + "% (" + scoreNum + "/" + totalNum + "). Your certificate is below, or download the badge for your email signature.";

      const certSvg = buildCertSvg(safeName, safeDate, scoreNum, totalNum, percentage, uid);
      document.getElementById("cert-svg-wrapper")!.innerHTML = certSvg;

      const badgeSvg = buildBadgeSvg(safeName, uid);
      document.getElementById("badge-svg-wrapper")!.innerHTML = badgeSvg;

      setupButtons(badgeSvg, name);
    });
  }

  document.addEventListener("astro:page-load", initCertificatePage);

  async function verifySig(name: string, date: string, score: string, total: string, sig: string): Promise<boolean> {
    var keyData = hexToBytes(SIGNING_KEY_HEX);
    var key = await crypto.subtle.importKey("raw", keyData, { name: "HMAC", hash: "SHA-256" }, false, ["verify"]);
    var data = new TextEncoder().encode(name + "|" + score + "|" + total + "|" + date);
    return crypto.subtle.verify("HMAC", key, hexToBytes(sig), data);
  }

  function buildCertSvg(safeName: string, safeDate: string, scoreNum: number, totalNum: number, percentage: number, uid: string): string {
    return '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 600" width="100%" height="auto" style="max-width:800px;border:1px solid #e5e7eb">' +
      '<defs><linearGradient id="certBorder-' + uid + '" x1="0%" y1="0%" x2="100%" y2="100%">' +
      '<stop offset="0%" stop-color="#3b82f6"/><stop offset="50%" stop-color="#8b5cf6"/><stop offset="100%" stop-color="#3b82f6"/>' +
      '</linearGradient></defs>' +
      '<rect x="0" y="0" width="800" height="600" fill="#0f172a"/>' +
      '<rect x="20" y="20" width="760" height="560" fill="none" stroke="url(#certBorder-' + uid + ')" stroke-width="3" rx="8"/>' +
      '<rect x="35" y="35" width="730" height="530" fill="none" stroke="url(#certBorder-' + uid + ')" stroke-width="1" stroke-dasharray="6 4" rx="4"/>' +
      '<text x="400" y="100" text-anchor="middle" fill="#3b82f6" font-family="monospace" font-size="18" font-weight="bold">SOCIETY FOR AV NORMS &amp; ENGINEERING</text>' +
      '<text x="400" y="160" text-anchor="middle" fill="#e2e8f0" font-family="sans-serif" font-size="28" font-weight="bold">Certificate of Completion</text>' +
      '<text x="400" y="210" text-anchor="middle" fill="#94a3b8" font-family="sans-serif" font-size="16">This certifies that</text>' +
      '<text x="400" y="280" text-anchor="middle" fill="#f8fafc" font-family="sans-serif" font-size="36" font-weight="bold">' + safeName + '</text>' +
      '<line x1="200" y1="300" x2="600" y2="300" stroke="#334155" stroke-width="1"/>' +
      '<text x="400" y="360" text-anchor="middle" fill="#94a3b8" font-family="sans-serif" font-size="16">has successfully completed the</text>' +
      '<text x="400" y="410" text-anchor="middle" fill="#f8fafc" font-family="sans-serif" font-size="24" font-weight="bold">SANE-F Founder Certification</text>' +
      '<text x="400" y="460" text-anchor="middle" fill="#94a3b8" font-family="sans-serif" font-size="16">with a score of ' + percentage + '% (' + scoreNum + ' / ' + totalNum + ')</text>' +
      '<text x="400" y="520" text-anchor="middle" fill="#64748b" font-family="sans-serif" font-size="14">Date: ' + safeDate + '</text>' +
      '<text x="400" y="560" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="11">This certificate is awarded as part of SANE\'s community education program.</text>' +
      '<text x="400" y="576" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="11">sane-av.org/certifications</text>' +
      '</svg>';
  }

  function buildBadgeSvg(safeName: string, uid: string): string {
    return '<svg xmlns="http://www.w3.org/2000/svg" width="400" height="60" viewBox="0 0 400 60">' +
      '<defs><linearGradient id="badgeBg-' + uid + '" x1="0%" y1="0%" x2="100%" y2="0%">' +
      '<stop offset="0%" stop-color="#1e293b"/><stop offset="100%" stop-color="#0f172a"/>' +
      '</linearGradient></defs>' +
      '<rect width="400" height="60" rx="6" fill="url(#badgeBg-' + uid + ')"/>' +
      '<rect width="400" height="60" rx="6" fill="none" stroke="#3b82f6" stroke-width="1.5" opacity="0.6"/>' +
      '<circle cx="28" cy="30" r="15" fill="#3b82f6" opacity="0.15"/>' +
      '<circle cx="28" cy="30" r="15" fill="none" stroke="#3b82f6" stroke-width="1.5"/>' +
      '<path d="M20 30 L26 36 L36 24" stroke="#60a5fa" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>' +
      '<text x="52" y="23" fill="#f8fafc" font-family="-apple-system,BlinkMacSystemFont,sans-serif" font-size="12.5" font-weight="700" letter-spacing="0.5">SANE-F CERTIFIED</text>' +
      '<text x="52" y="40" fill="#94a3b8" font-family="-apple-system,BlinkMacSystemFont,sans-serif" font-size="10.5">' + safeName + ' \u2022 Society for AV Norms &amp; Engineering</text>' +
      '</svg>';
  }

  function svgToPngBlob(svg: string, width: number, height: number): Promise<Blob> {
    return new Promise(function(resolve, reject) {
      var svgBlob = new Blob([svg], { type: "image/svg+xml;charset=utf-8" });
      var url = URL.createObjectURL(svgBlob);
      var img = new Image();
      img.onload = function() {
        URL.revokeObjectURL(url);
        var canvas = document.createElement("canvas");
        canvas.width = width;
        canvas.height = height;
        var ctx = canvas.getContext("2d")!;
        ctx.drawImage(img, 0, 0, width, height);
        canvas.toBlob(function(blob) {
          if (blob) resolve(blob);
          else reject(new Error("Failed to create PNG"));
        }, "image/png");
      };
      img.onerror = function() {
        URL.revokeObjectURL(url);
        reject(new Error("Failed to load SVG"));
      };
      img.src = url;
    });
  }

  function downloadBlob(blob: Blob, filename: string) {
    var url = URL.createObjectURL(blob);
    var a = document.createElement("a");
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }

  function setupButtons(badgeSvg: string, name: string) {
    document.getElementById("btn-download-pdf")!.addEventListener("click", function() {
      window.print();
    });

    document.getElementById("btn-badge-svg")!.addEventListener("click", function() {
      var blob = new Blob([badgeSvg], { type: "image/svg+xml" });
      downloadBlob(blob, "sane-founder-badge-" + sanitizeFilename(name) + ".svg");
    });

    var badgeSizes: Record<string, [number, number]> = { lg: [800, 120], md: [400, 60], sm: [200, 30] };
    ["lg", "md", "sm"].forEach(function(s) {
      document.getElementById("btn-badge-png-" + s)!.addEventListener("click", async function() {
        try {
          var dims = badgeSizes[s];
          var blob = await svgToPngBlob(badgeSvg, dims[0], dims[1]);
          downloadBlob(blob, "sane-founder-badge-" + sanitizeFilename(name) + "-" + dims[0] + "w.png");
        } catch (e) {
          alert("Failed to generate PNG. Please try again.");
        }
      });
    });
  }

  function sanitizeFilename(str: string): string {
    return str.replace(/[^a-zA-Z0-9_-]/g, "_").substring(0, 50);
  }

  function escapeXml(str: string): string {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&apos;");
  }
</script>
