---
import Base from "@/layouts/Base.astro";
import { getCollection, render } from "astro:content";
import { getGlossaryTerms } from "@/lib/glossary";
import type { GlossaryTerm } from "@/lib/glossary";
import type { CollectionEntry } from "astro:content";

// Every term gets a page: markdown-backed terms render their full article,
// JSON-only terms render their definition.
export async function getStaticPaths() {
  const mdEntries = await getCollection("glossary");
  const mdById = new Map(mdEntries.map((e) => [e.id, e]));
  const terms = await getGlossaryTerms();
  const slugByName = new Map(terms.map((t) => [t.term, t.redirectTo ?? t.slug]));
  return terms.map((term) => ({
    params: { slug: term.slug },
    props: { term, entry: mdById.get(term.slug) ?? null, slugByName },
  }));
}

interface Props {
  term: GlossaryTerm;
  entry: CollectionEntry<"glossary"> | null;
  slugByName: Map<string, string>;
}

const { term, entry, slugByName } = Astro.props;

if (entry?.data.redirectTo) {
  return Astro.redirect(`/glossary/${entry.data.redirectTo}`, 301);
}

const Content = entry ? (await render(entry)).Content : null;

const termName = term.term;
const categories = term.categories;
const abbreviation = term.abbreviation;
const relatedTerms = term.relatedTerms;
const description = term.definition
  ? term.definition.slice(0, 155)
  : `Definition of ${termName} in professional AV.`;
---

<Base title={abbreviation ? `${abbreviation} (${termName})` : termName} description={description}>
  <section class="section-sm">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-10">

          <!-- Header -->
          <div class="mb-8">
            <h1 class="mb-3">
              {abbreviation ? `${abbreviation} (${termName})` : termName}
            </h1>
            <div class="flex flex-wrap gap-2">
              {categories.map((cat) => (
                <a href={`/glossary?category=${encodeURIComponent(cat)}`} class="rounded bg-light px-3 py-1 text-sm hover:text-primary dark:bg-darkmode-light dark:hover:text-darkmode-primary">{cat}</a>
              ))}
            </div>
          </div>

          <!-- Content -->
          {Content ? (
            <div class="content mb-10">
              <Content />
            </div>
          ) : (
            <div class="content mb-10">
              <p>{term.definition}</p>
            </div>
          )}

          <!-- Related Terms -->
          {relatedTerms.length > 0 && (
            <div class="mb-8 rounded-lg border border-border p-6 dark:border-darkmode-border">
              <h3 class="mb-3">Related Terms</h3>
              <div class="flex flex-wrap gap-2">
                {relatedTerms.map((t: string) =>
                  slugByName.has(t) ? (
                    <a href={`/glossary/${slugByName.get(t)}`} class="rounded bg-light px-3 py-1 text-sm text-primary hover:underline dark:bg-darkmode-light dark:text-darkmode-primary">{t}</a>
                  ) : (
                    <span class="rounded bg-light px-3 py-1 text-sm dark:bg-darkmode-light">{t}</span>
                  )
                )}
              </div>
            </div>
          )}

          <!-- Contribute -->
          <hr class="mb-6 border-border dark:border-darkmode-border" />
          <p class="text-sm text-text-light dark:text-darkmode-text-light">
            Want to improve this definition?
            <a href={`https://github.com/sane-av/sane-av.github.io/issues/new?template=content_submission.yml&title=${encodeURIComponent("Glossary: " + termName)}`} target="_blank" rel="noopener" class="underline hover:text-primary dark:hover:text-darkmode-primary">
              Submit a suggestion on GitHub
            </a>.
          </p>

        </div>
      </div>
    </div>
  </section>
</Base>
