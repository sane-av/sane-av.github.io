---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const mdEntries = await getCollection('glossary');
  
  const paths = mdEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
  
  return paths;
}

const { entry } = Astro.props;

if (entry.data.redirectTo) {
  return Astro.redirect(`/glossary/${entry.data.redirectTo}`, 301);
}

const { Content } = await render(entry);

const termName = entry.data.term;
const categories = [entry.data.category];
const abbreviation = entry.data.abbreviation ?? null;
const relatedTerms = entry.data.relatedTerms ?? [];

const description = `Definition of ${termName} in professional AV.`;
---

<BaseLayout title={termName} description={description}>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> <span>›</span>
        <a href="/glossary">Glossary</a> <span>›</span>
        <span>{termName}</span>
      </nav>
      <h1>
        {abbreviation ? `${abbreviation} (${termName})` : termName}
      </h1>
      <div class="glossary-tags-inline">
        {categories.map((cat) => <span class="tag">{cat}</span>)}
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container content-width">
      <article class="prose">
        <Content />
      </article>

      {relatedTerms.length > 0 && (
        <div class="related-terms mt-3">
          <h3 class="mb-1">Related Terms</h3>
          <div class="card-tags">
            {relatedTerms.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
      )}

      <hr />
      <p class="text-muted">
        Want to improve this definition?
        <a href={`https://github.com/sane-av/sane-av.github.io/issues/new?template=content_submission.yml&title=${encodeURIComponent('Glossary: ' + termName)}`} target="_blank" rel="noopener">
          Submit a suggestion on GitHub
        </a>.
      </p>
    </div>
  </section>
</BaseLayout>
