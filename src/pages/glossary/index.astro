---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/partials/PageHeader.astro";
import { getGlossaryTerms } from "@/lib/glossary";
import type { GlossaryTerm } from "@/lib/glossary";

const merged: GlossaryTerm[] = await getGlossaryTerms();

const allCats = new Set<string>();
for (const e of merged) {
  for (const c of e.categories) allCats.add(c);
}
const categories = [...allCats].sort();
// Bucket terms iOS-contacts style: A-Z, with digits/symbols grouped under "#" (listed first)
const bucketOf = (term: string) => (/^[a-z]/i.test(term) ? term[0].toUpperCase() : "#");
const sectionIdOf = (letter: string) => `section-${letter === "#" ? "num" : letter}`;

const termsByLetter = new Map<string, GlossaryTerm[]>();
for (const entry of merged) {
  const letter = bucketOf(entry.term);
  const group = termsByLetter.get(letter);
  if (group) group.push(entry);
  else termsByLetter.set(letter, [entry]);
}
const allLetters = [...termsByLetter.keys()].sort((a, b) =>
  a === "#" ? -1 : b === "#" ? 1 : a.localeCompare(b)
);
const total = merged.length;
---

<Base title="Glossary" description="Community-maintained definitions of common AV terminology.">
  <PageHeader title="AV Glossary" />

  <section class="pt-8 pb-24">
    <div class="container">

      <div id="glossary-toolbar" class="sticky top-[72px] z-20 bg-body/95 pr-4 shadow-sm backdrop-blur-sm dark:bg-darkmode-body/95">
        <!-- border + content start after the rail gutter so the break never crosses the index scroller -->
        <div class="ml-10 border-b border-border/80 pb-3 pt-6 dark:border-darkmode-border/60 sm:ml-12">
          <div class="mb-3 flex items-center gap-2">
            <input
              type="search"
              id="glossary-search"
              class="form-input w-full"
              placeholder={`Search ${total} terms...`}
              aria-label="Search glossary"
            />
            <button
              type="button"
              id="glossary-filters-toggle"
              class="filter-pill glossary-filters-toggle shrink-0 whitespace-nowrap"
              aria-expanded="false"
              aria-controls="glossary-filters"
            >
              Filters ▾
            </button>
          </div>
          <div id="glossary-filters" class="glossary-filters">
            <span class="text-xs font-medium text-text-light/80 dark:text-darkmode-text-light/80">Filter:</span>
            {categories.map((cat) => (
              <button type="button" class="filter-pill" data-category={cat}>
                {cat}
              </button>
            ))}
            <button id="filter-clear" class="hidden text-xs text-text-light underline hover:text-primary dark:text-darkmode-text-light dark:hover:text-darkmode-primary transition-colors">
              Clear
            </button>
          </div>
        </div>
      </div>

      <nav id="glossary-quicknav" class="glossary-rail hidden" aria-label="Letter quick navigation" data-letters={allLetters.join("")}>
        {allLetters.map((letter) => (
          <button type="button" class="glossary-jump glossary-rail-btn" data-letter={letter} aria-label={`Jump to ${letter === "#" ? "numbers and symbols" : letter}`}>
            {letter}
          </button>
        ))}
      </nav>
      <div id="glossary-tooltip" class="glossary-bubble hidden" aria-hidden="true">
        <span id="glossary-tooltip-letter"></span>
      </div>

      <div id="glossary-content" class="mt-6 pl-10 sm:pl-12">
        <div class="mb-4 text-sm text-text-light dark:text-darkmode-text-light">
          <span id="glossary-count">{total} terms</span>
          <span id="glossary-filtered" class="hidden ml-2"></span>
        </div>

        {merged.length === 0 ? (
          <div class="rounded-lg border border-border p-8 text-center dark:border-darkmode-border">
            <a href="https://github.com/sane-av/sane-av.github.io" class="underline hover:text-primary dark:hover:text-darkmode-primary">Contribute the first term &rarr;</a>
          </div>
        ) : (
          allLetters.map((letter) => {
            const letterTerms = termsByLetter.get(letter) ?? [];
            return (
              <div id={sectionIdOf(letter)} data-letter={letter} class="glossary-section scroll-mt-56 rounded-lg border border-border bg-light px-5 py-4 mb-6 dark:border-darkmode-border dark:bg-darkmode-light">
                <div class="mb-4 flex items-center gap-2">
                  <span class="flex h-8 w-8 items-center justify-center rounded-md bg-primary text-sm font-bold font-mono text-white dark:bg-darkmode-primary dark:text-black">{letter}</span>
                  <span class="h-px flex-1 bg-border/60 dark:bg-darkmode-border/60"></span>
                </div>
                <div class="space-y-3">
                  {letterTerms.map((entry) => {
                    const catData = entry.categories.join(",");
                    return (
                      <div
                        class="glossary-item"
                        data-term={entry.term.toLowerCase()}
                        data-categories={catData}
                        data-letter={letter}
                      >
                        <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                          <span class="font-semibold text-text-dark dark:text-darkmode-text-dark">
                            <a href={`/glossary/${entry.redirectTo ?? entry.slug}`} class="text-primary hover:underline dark:text-darkmode-primary">
                              {entry.abbreviation || entry.term}
                            </a>
                          </span>
                          {entry.abbreviation && (
                            <span class="text-sm text-text-light/60 dark:text-darkmode-text-light/60">{entry.term}</span>
                          )}
                        </div>
                        <p class="text-sm leading-relaxed text-text-light [overflow-wrap:anywhere] dark:text-darkmode-text-light">
                          {entry.definition}
                        </p>
                        {entry.categories.length > 0 && (
                          <span class="flex flex-wrap gap-1">
                            {entry.categories.map((cat: string) => (
                              <span class="text-xs text-text-light/40 dark:text-darkmode-text-light/40">{cat}</span>
                            ))}
                          </span>
                        )}
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })
        )}

        <p id="glossary-no-results" class="mt-8 hidden text-center text-sm text-text-light dark:text-darkmode-text-light">
          No terms match. Try different search or category.
        </p>
      </div>
    </div>
  </section>
</Base>

<script src="../../lib/glossaryPage.ts"></script>
