---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import avixaTerms from '../../data/glossary/avixa-terms.json';

// Load the content collection entries (rich .md pages)
const mdEntries = await getCollection('glossary');

// Build a lookup by slug → content collection entry
const mdBySlug = new Map<string, (typeof mdEntries)[number]>();
for (const e of mdEntries) {
  mdBySlug.set(e.id, e);
}

// Merge: JSON terms provide the base, .md entries override when they exist
interface GlossaryEntry {
  term: string;
  slug: string;
  definition: string;
  categories: string[];
  abbreviation: string | null;
  relatedTerms: string[];
  hasPage: boolean;
}

const merged: GlossaryEntry[] = [];

// First, add all JSON terms
for (const t of avixaTerms) {
  const mdEntry = mdBySlug.get(t.slug);
  merged.push({
    term: t.term,
    slug: t.slug,
    definition: t.definition,
    categories: t.categories ?? [t.category ?? 'General'],
    abbreviation: t.abbreviation,
    relatedTerms: t.relatedTerms ?? [],
    hasPage: !!mdEntry,
  });
}

// Then add any .md entries that don't have a JSON counterpart
for (const e of mdEntries) {
  if (!merged.find((m) => m.slug === e.id)) {
    merged.push({
      term: e.data.term,
      slug: e.id,
      definition: '',
      categories: [e.data.category],
      abbreviation: e.data.abbreviation ?? null,
      relatedTerms: e.data.relatedTerms ?? [],
      hasPage: true,
    });
  }
}

// Sort alphabetically
merged.sort((a, b) => a.term.localeCompare(b.term));

// Collect unique categories from all entries
const allCats = new Set<string>();
for (const e of merged) {
  for (const c of e.categories) allCats.add(c);
}
const categories = [...allCats].sort();
const allLetters = [...new Set(merged.map((e) => e.term[0].toUpperCase()))].sort();
const total = merged.length;
const pageCount = merged.filter((e) => e.hasPage).length;
---

<BaseLayout title="Glossary" description="Community-maintained definitions of common AV terminology.">
  <div class="page-header">
    <div class="container">
      <h1>AV Glossary</h1>
      <p>Community-maintained definitions of professional AV terms and abbreviations.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="glossary-filters">
        <input
          type="search"
          id="glossary-search"
          placeholder="Search terms..."
          aria-label="Search glossary"
        />
      </div>

      {categories.length > 0 && (
        <div class="glossary-categories" id="glossary-categories">
          <span class="text-small label-heading">Category:</span>
          {categories.map((cat) => (
            <button type="button" class="tag tag-orange glossary-tag" data-category={cat}>
              {cat}
            </button>
          ))}
        </div>
      )}

      <div class="glossary-jump" id="glossary-jump">
        {allLetters.map((letter) => (
          <button type="button" class="glossary-jump-btn" data-letter={letter}>
            {letter}
          </button>
        ))}
      </div>

      <p id="glossary-count" class="text-muted mt-1">{total} terms</p>

      {merged.length === 0 ? (
        <p class="text-muted">
          No glossary entries yet.
          <a href="https://github.com/sane-av/sane-av.github.io">Contribute the first term &rarr;</a>
        </p>
      ) : (
        <ul class="glossary-list" id="glossary-list">
          {merged.map((entry, i) => {
            const letter = entry.term[0].toUpperCase();
            const prevLetter = i > 0 ? merged[i - 1].term[0].toUpperCase() : null;
            const isNewLetter = letter !== prevLetter;
            const catData = entry.categories.join(',');
            return (
              <>
                {isNewLetter && (
                  <li id={`letter-${letter}`} class="glossary-letter" data-letter={letter}>
                    {letter}
                  </li>
                )}
                <li
                  class="glossary-item"
                  data-term={entry.term.toLowerCase()}
                  data-categories={catData}
                  data-letter={letter}
                >
                  <div class="glossary-term">
                    <a href={`/glossary/${entry.slug}`}>
                      {entry.abbreviation ? `${entry.abbreviation} (${entry.term})` : entry.term}
                    </a>
                    <span class="glossary-tags-inline">
                      {entry.categories.map((cat) => (
                        <span class="tag tag-orange ml-1">{cat}</span>
                      ))}
                    </span>
                  </div>
                  <div class="glossary-definition text-muted">
                    {entry.definition}
                  </div>
                  {entry.hasPage && (
                    <div class="mt-1">
                      <a href={`/glossary/${entry.slug}`} class="text-small">Expanded definition &rarr;</a>
                    </div>
                  )}
                  {entry.relatedTerms.length > 0 && (
                    <div class="text-small mt-1">
                      Related: {entry.relatedTerms.join(', ')}
                    </div>
                  )}
                </li>
              </>
            );
          })}
        </ul>
        <p id="glossary-no-results" class="text-muted mt-3" style="display:none">
          No terms match your filters. Try adjusting your search or clearing the category.
        </p>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const searchInput = document.getElementById('glossary-search') as HTMLInputElement;
  const tagButtons = document.querySelectorAll<HTMLButtonElement>('.glossary-tag');
  const jumpButtons = document.querySelectorAll<HTMLButtonElement>('.glossary-jump-btn');
  const items = document.querySelectorAll<HTMLLIElement>('.glossary-item');
  const letterHeadings = document.querySelectorAll<HTMLLIElement>('.glossary-letter');
  const countEl = document.getElementById('glossary-count')!;
  const noResults = document.getElementById('glossary-no-results')!;
  const totalItems = items.length;

  let activeCategory = '';

  tagButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category!;
      activeCategory = activeCategory === category ? '' : category;
      applyFilters();
    });
  });

  jumpButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const letter = btn.dataset.letter!;
      const heading = document.getElementById(`letter-${letter}`);
      if (heading) {
        heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  searchInput.addEventListener('input', applyFilters);

  function applyFilters() {
    const query = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    tagButtons.forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.category === activeCategory);
    });

    const visibleLetters = new Set<string>();

    items.forEach((item) => {
      const matchesSearch = !query || item.dataset.term!.includes(query);
      // Check if the item's categories include the active category
      const itemCategories = (item.dataset.categories || '').split(',');
      const matchesCategory = !activeCategory || itemCategories.includes(activeCategory);
      const show = matchesSearch && matchesCategory;

      (item as HTMLElement).style.display = show ? '' : 'none';
      if (show) {
        visibleCount++;
        visibleLetters.add(item.dataset.letter!);
      }
    });

    letterHeadings.forEach((heading) => {
      const letter = heading.dataset.letter!;
      (heading as HTMLElement).style.display = visibleLetters.has(letter) ? '' : 'none';
    });

    jumpButtons.forEach((btn) => {
      btn.classList.toggle('dim', !visibleLetters.has(btn.dataset.letter!));
    });

    const filtering = query || activeCategory;
    countEl.textContent = filtering ? `${visibleCount} of ${totalItems} terms` : `${totalItems} terms`;
    (noResults as HTMLElement).style.display = filtering && visibleCount === 0 ? '' : 'none';
  }
</script>
