---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/partials/PageHeader.astro";
import { getGlossaryTerms } from "@/lib/glossary";
import type { GlossaryTerm } from "@/lib/glossary";

const merged: GlossaryTerm[] = await getGlossaryTerms();

const allCats = new Set<string>();
for (const e of merged) {
  for (const c of e.categories) allCats.add(c);
}
const categories = [...allCats].sort();
const allLetters = [...new Set(merged.map((e) => e.term[0].toUpperCase()))].sort();
const total = merged.length;
---

<Base title="Glossary" description="Community-maintained definitions of common AV terminology.">
  <PageHeader title="AV Glossary" />

  <section class="section-sm">
    <div class="container">
      <p class="mb-6 text-text-light dark:text-darkmode-text-light">
        Community-maintained definitions of professional AV terms and abbreviations.
      </p>

      <!-- Search -->
      <div class="mb-6">
        <input
          type="search"
          id="glossary-search"
          class="form-input w-full"
          placeholder="Search terms..."
          aria-label="Search glossary"
        />
      </div>

      <!-- Category filters -->
      {categories.length > 0 && (
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <span class="mr-2 text-sm font-semibold">Categories:</span>
          {categories.map((cat) => (
            <button type="button" class="filter-tag rounded bg-light px-3 py-1 text-sm hover:bg-primary hover:text-white dark:bg-darkmode-light dark:hover:bg-darkmode-primary dark:hover:text-text-dark" data-category={cat}>
              {cat}
            </button>
          ))}
          <button id="tag-clear" class="ml-2 hidden text-sm text-text-light underline hover:text-primary dark:text-darkmode-text-light dark:hover:text-darkmode-primary">Clear</button>
        </div>
      )}

      <!-- A-Z Jump -->
      <div class="mb-6 flex flex-wrap gap-1">
        {allLetters.map((letter) => (
          <button type="button" class="glossary-jump-btn rounded bg-light px-2 py-1 text-sm font-mono hover:bg-primary hover:text-white dark:bg-darkmode-light dark:hover:bg-darkmode-primary dark:hover:text-text-dark" data-letter={letter}>
            {letter}
          </button>
        ))}
      </div>

      <p id="glossary-count" class="mb-6 text-text-light dark:text-darkmode-text-light">{total} terms</p>

      {merged.length === 0 ? (
        <div class="rounded-lg border border-border p-8 text-center dark:border-darkmode-border">
          <p class="text-text-light dark:text-darkmode-text-light">
            No glossary entries yet.
            <a href="https://github.com/sane-av/sane-av.github.io" class="underline hover:text-primary dark:hover:text-darkmode-primary"> Contribute the first term &rarr;</a>
          </p>
        </div>
      ) : (
        <div class="space-y-1" id="glossary-list">
          {merged.map((entry, i) => {
            const letter = entry.term[0].toUpperCase();
            const prevLetter = i > 0 ? merged[i - 1].term[0].toUpperCase() : null;
            const isNewLetter = letter !== prevLetter;
            const catData = entry.categories.join(",");
            return (
              <>
                {isNewLetter && (
                  <h3 id={`letter-${letter}`} class="glossary-letter pt-6 h4 font-bold text-primary dark:text-darkmode-primary border-t border-border dark:border-darkmode-border mt-2" data-letter={letter}>
                    {letter}
                  </h3>
                )}
                <div
                  class="glossary-item rounded px-3 py-2 transition-colors hover:bg-light dark:hover:bg-darkmode-light"
                  data-term={entry.term.toLowerCase()}
                  data-categories={catData}
                  data-letter={letter}
                >
                  <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                    <span class="font-semibold text-text-dark dark:text-darkmode-text-dark">
                      {entry.hasPage ? (
                        <a href={`/glossary/${entry.redirectTo ?? entry.slug}`} class="text-primary hover:underline dark:text-darkmode-primary">
                          {entry.abbreviation ? `${entry.abbreviation} (${entry.term})` : entry.term}
                        </a>
                      ) : (
                        <>{entry.abbreviation ? `${entry.abbreviation} (${entry.term})` : entry.term}</>
                      )}
                    </span>
                    <span class="flex flex-wrap gap-1">
                      {entry.categories.map((cat: string) => (
                        <span class="rounded bg-light px-1.5 py-0.5 text-xs text-text-light dark:bg-darkmode-body dark:text-darkmode-text-light">{cat}</span>
                      ))}
                    </span>
                  </div>
                  <p class="mt-1 text-sm text-text-light dark:text-darkmode-text-light">{entry.definition}</p>
                  {entry.relatedTerms.length > 0 && (
                    <p class="mt-1 text-xs text-text-light dark:text-darkmode-text-light">
                      Related: {entry.relatedTerms.join(", ")}
                    </p>
                  )}
                </div>
              </>
            );
          })}
        </div>
      )}
      <p id="glossary-no-results" class="mt-6 hidden text-center text-text-light dark:text-darkmode-text-light">
        No terms match your filters. Try adjusting your search or clearing the category.
      </p>
    </div>
  </section>
</Base>

<script>
  const searchInput = document.getElementById("glossary-search") as HTMLInputElement;
  const tagButtons = document.querySelectorAll<HTMLButtonElement>(".filter-tag");
  const jumpButtons = document.querySelectorAll<HTMLButtonElement>(".glossary-jump-btn");
  const items = document.querySelectorAll<HTMLElement>(".glossary-item");
  const letterHeadings = document.querySelectorAll<HTMLElement>(".glossary-letter");
  const countEl = document.getElementById("glossary-count")!;
  const noResults = document.getElementById("glossary-no-results")!;
  const clearBtn = document.getElementById("tag-clear")!;
  const totalItems = items.length;

  let activeCategory = "";

  tagButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.dataset.category!;
      activeCategory = activeCategory === category ? "" : category;
      applyFilters();
    });
  });

  clearBtn.addEventListener("click", () => { activeCategory = ""; applyFilters(); });

  jumpButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const letter = btn.dataset.letter!;
      const heading = document.getElementById(`letter-${letter}`);
      if (heading) heading.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });

  searchInput.addEventListener("input", applyFilters);

  function applyFilters() {
    const query = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;
    const visibleLetters = new Set<string>();

    tagButtons.forEach((btn) => {
      const match = btn.dataset.category === activeCategory;
      btn.classList.toggle("!bg-primary !text-white", match);
      btn.classList.toggle("dark:!bg-darkmode-primary dark:!text-text-dark", match);
    });

    items.forEach((item) => {
      const matchesSearch = !query || item.dataset.term!.includes(query);
      const itemCategories = (item.dataset.categories || "").split(",");
      const matchesCategory = !activeCategory || itemCategories.includes(activeCategory);
      const show = matchesSearch && matchesCategory;
      item.classList.toggle("hidden", !show);
      if (show) { visibleCount++; visibleLetters.add(item.dataset.letter!); }
    });

    letterHeadings.forEach((heading) => {
      heading.classList.toggle("hidden", !visibleLetters.has(heading.dataset.letter!));
    });

    jumpButtons.forEach((btn) => {
      if (visibleLetters.has(btn.dataset.letter!)) {
        btn.classList.remove("opacity-30");
      } else {
        btn.classList.add("opacity-30");
      }
    });

    const filtering = query || activeCategory;
    countEl.textContent = filtering ? `${visibleCount} of ${totalItems} terms` : `${totalItems} terms`;
    noResults.classList.toggle("hidden", !(filtering && visibleCount === 0));
    clearBtn.classList.toggle("!inline-block", !!activeCategory);
  }
</script>
