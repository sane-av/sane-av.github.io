---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('glossary'))
  .sort((a, b) => a.data.term.localeCompare(b.data.term));

const categories = [...new Set(entries.map((e) => e.data.category))].sort();
const allLetters = [...new Set(entries.map((e) => e.data.term[0].toUpperCase()))].sort();
const total = entries.length;
---

<BaseLayout title="Glossary" description="Definitions for common AV terminology, from dBu to throw ratio.">
  <div class="page-header">
    <div class="container">
      <h1>AV Glossary</h1>
      <p>Community-maintained definitions of common professional AV terms and abbreviations.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="glossary-filters">
        <input
          type="search"
          id="glossary-search"
          placeholder="Search terms..."
          aria-label="Search glossary"
        />
      </div>

      {categories.length > 0 && (
        <div class="glossary-categories" id="glossary-categories">
          <span class="text-small label-heading">Category:</span>
          {categories.map((cat) => (
            <button type="button" class="tag tag-orange glossary-tag" data-category={cat}>
              {cat}
            </button>
          ))}
        </div>
      )}

      <div class="glossary-jump" id="glossary-jump">
        {allLetters.map((letter) => (
          <button type="button" class="glossary-jump-btn" data-letter={letter}>
            {letter}
          </button>
        ))}
      </div>

      <p id="glossary-count" class="text-muted mt-1">{total} terms</p>

      {entries.length === 0 ? (
        <p class="text-muted">
          No glossary entries yet.
          <a href="https://github.com/sane-av/sane-av.github.io">Contribute the first term &rarr;</a>
        </p>
      ) : (
        <ul class="glossary-list" id="glossary-list">
          {entries.map((entry, i) => {
            const letter = entry.data.term[0].toUpperCase();
            const prevLetter = i > 0 ? entries[i - 1].data.term[0].toUpperCase() : null;
            const isNewLetter = letter !== prevLetter;
            return (
              <>
                {isNewLetter && (
                  <li id={`letter-${letter}`} class="glossary-letter" data-letter={letter}>
                    {letter}
                  </li>
                )}
                <li
                  class="glossary-item"
                  data-term={entry.data.term.toLowerCase()}
                  data-category={entry.data.category}
                  data-letter={letter}
                >
                  <div class="glossary-term">
                    {entry.data.term}
                    {entry.data.abbreviation && (
                      <code class="glossary-abbr">{entry.data.abbreviation}</code>
                    )}
                    <span class="tag tag-orange ml-1">{entry.data.category}</span>
                  </div>
                  <div class="prose text-muted">
                    <a href={`/glossary/${entry.id}`}>View full definition &rarr;</a>
                  </div>
                  {entry.data.relatedTerms.length > 0 && (
                    <div class="text-small mt-1">
                      Related: {entry.data.relatedTerms.join(', ')}
                    </div>
                  )}
                </li>
              </>
            );
          })}
        </ul>
        <p id="glossary-no-results" class="text-muted mt-3" style="display:none">
          No terms match your filters. Try adjusting your search or clearing the category.
        </p>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const searchInput = document.getElementById('glossary-search') as HTMLInputElement;
  const tagButtons = document.querySelectorAll<HTMLButtonElement>('.glossary-tag');
  const jumpButtons = document.querySelectorAll<HTMLButtonElement>('.glossary-jump-btn');
  const items = document.querySelectorAll<HTMLLIElement>('.glossary-item');
  const letterHeadings = document.querySelectorAll<HTMLLIElement>('.glossary-letter');
  const countEl = document.getElementById('glossary-count')!;
  const noResults = document.getElementById('glossary-no-results')!;
  const totalItems = items.length;

  let activeCategory = '';

  tagButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category!;
      activeCategory = activeCategory === category ? '' : category;
      applyFilters();
    });
  });

  jumpButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const letter = btn.dataset.letter!;
      const heading = document.getElementById(`letter-${letter}`);
      if (heading) {
        heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  searchInput.addEventListener('input', applyFilters);

  function applyFilters() {
    const query = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    tagButtons.forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.category === activeCategory);
    });

    const visibleLetters = new Set<string>();

    items.forEach((item) => {
      const matchesSearch = !query || item.dataset.term!.includes(query);
      const matchesCategory = !activeCategory || item.dataset.category === activeCategory;
      const show = matchesSearch && matchesCategory;

      (item as HTMLElement).style.display = show ? '' : 'none';
      if (show) {
        visibleCount++;
        visibleLetters.add(item.dataset.letter!);
      }
    });

    letterHeadings.forEach((heading) => {
      const letter = heading.dataset.letter!;
      (heading as HTMLElement).style.display = visibleLetters.has(letter) ? '' : 'none';
    });

    jumpButtons.forEach((btn) => {
      btn.classList.toggle('dim', !visibleLetters.has(btn.dataset.letter!));
    });

    const filtering = query || activeCategory;
    countEl.textContent = filtering ? `${visibleCount} of ${totalItems} terms` : `${totalItems} terms`;
    (noResults as HTMLElement).style.display = filtering && visibleCount === 0 ? '' : 'none';
  }
</script>
