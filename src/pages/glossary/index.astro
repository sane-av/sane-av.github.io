---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/partials/PageHeader.astro";
import { getGlossaryTerms } from "@/lib/glossary";
import type { GlossaryTerm } from "@/lib/glossary";

const merged: GlossaryTerm[] = await getGlossaryTerms();

const allCats = new Set<string>();
for (const e of merged) {
  for (const c of e.categories) allCats.add(c);
}
const categories = [...allCats].sort();
const allLetters = [...new Set(merged.map((e) => e.term[0].toUpperCase()))].sort();
const total = merged.length;
---

<Base title="Glossary" description="Community-maintained definitions of common AV terminology.">
  <PageHeader title="AV Glossary" />

  <section class="section-sm">
    <div class="container">

      <div class="mb-6 flex flex-col gap-3 sm:flex-row">
        <div class="relative flex-1">
          <input
            type="search"
            id="glossary-search"
            class="form-input w-full !py-2.5"
            placeholder="Search {total} terms..."
            aria-label="Search glossary"
          />
        </div>
      </div>

      <div class="mb-4 flex flex-wrap items-center gap-1.5">
        {allLetters.map((letter) => (
          <button type="button" class="glossary-jump rounded px-2 py-1 text-xs font-mono font-semibold text-text-light hover:text-primary hover:bg-primary/10 dark:text-darkmode-text-light dark:hover:text-darkmode-primary dark:hover:bg-darkmode-primary/10 transition-colors" data-letter={letter}>
            {letter}
          </button>
        ))}
      </div>

      {categories.length > 0 && (
        <div class="mb-4 flex flex-wrap items-center gap-1.5">
          <span class="text-xs font-semibold text-text-light dark:text-darkmode-text-light">Filter:</span>
          {categories.map((cat) => (
            <button type="button" class="filter-pill !px-2 !py-0.5 !text-xs" data-category={cat}>
              {cat}
            </button>
          ))}
          <button id="filter-clear" class="hidden text-xs text-text-light underline hover:text-primary dark:text-darkmode-text-light dark:hover:text-darkmode-primary transition-colors">
            Clear
          </button>
        </div>
      )}

      <div class="mb-3 flex items-center justify-between text-xs text-text-light dark:text-darkmode-text-light">
        <span id="glossary-count">{total} terms</span>
        <span id="glossary-filtered" class="hidden"></span>
      </div>

      {merged.length === 0 ? (
        <div class="rounded-lg border border-border p-8 text-center dark:border-darkmode-border">
          <a href="https://github.com/sane-av/sane-av.github.io" class="underline hover:text-primary dark:hover:text-darkmode-primary">Contribute the first term &rarr;</a>
        </div>
      ) : (
        <div id="glossary-list" class="rounded-lg border border-border dark:border-darkmode-border divide-y divide-border/50 dark:divide-darkmode-border/50 overflow-hidden">
          {merged.map((entry) => {
            const catData = entry.categories.join(",");
            return (
              <div
                class="glossary-item flex flex-col sm:flex-row sm:items-baseline gap-x-4 gap-y-1 px-4 py-2.5 transition-colors hover:bg-light dark:hover:bg-darkmode-light"
                data-term={entry.term.toLowerCase()}
                data-categories={catData}
                data-letter={entry.term[0].toUpperCase()}
              >
                <div class="flex items-baseline gap-x-2 min-w-0 sm:w-48 shrink-0">
                  <span class="text-xs text-text-light dark:text-darkmode-text-light shrink-0">
                    {entry.term[0].toUpperCase()}
                  </span>
                  <span class="font-semibold text-text-dark dark:text-darkmode-text-dark truncate">
                    {entry.hasPage ? (
                      <a href={`/glossary/${entry.redirectTo ?? entry.slug}`} class="text-primary hover:underline dark:text-darkmode-primary">
                        {entry.abbreviation ? entry.abbreviation : entry.term}
                      </a>
                    ) : (
                      <>{entry.abbreviation ? entry.abbreviation : entry.term}</>
                    )}
                  </span>
                </div>
                <div class="text-sm text-text-light dark:text-darkmode-text-light line-clamp-1 min-w-0 flex-1">
                  {entry.abbreviation && <span class="text-xs text-text-light/60 dark:text-darkmode-text-light/60">{entry.term}</span>}
                  {entry.abbreviation && <span class="mx-1.5 text-border dark:text-darkmode-border">&middot;</span>}
                  {entry.definition}
                </div>
                <div class="flex gap-1 shrink-0">
                  {entry.categories.slice(0, 2).map((cat: string) => (
                    <span class="rounded bg-light px-1.5 py-0.5 text-[10px] text-text-light/70 dark:bg-darkmode-body dark:text-darkmode-text-light/70">{cat}</span>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      )}

      <p id="glossary-no-results" class="mt-6 hidden text-center text-sm text-text-light dark:text-darkmode-text-light">
        No terms match. Try a different search or category.
      </p>
    </div>
  </section>
</Base>

<script>
  (function() {
    var searchInput = document.getElementById("glossary-search") as HTMLInputElement;
    var items = document.querySelectorAll<HTMLElement>(".glossary-item");
    var categoryBtns = document.querySelectorAll<HTMLButtonElement>(".filter-pill");
    var jumpBtns = document.querySelectorAll<HTMLButtonElement>(".glossary-jump");
    var countEl = document.getElementById("glossary-count")!;
    var filteredEl = document.getElementById("glossary-filtered")!;
    var noResults = document.getElementById("glossary-no-results")!;
    var clearBtn = document.getElementById("filter-clear")!;
    var totalItems = items.length;
    var searchTimer = 0;

    var params = new URLSearchParams(window.location.search);
    var activeCategory = params.get("category") || "";
    var activeQuery = params.get("q") || "";

    if (activeQuery) searchInput.value = activeQuery;

    function updateUrl() {
      var url = new URL(window.location.href);
      var query = searchInput.value.trim();
      if (activeCategory) url.searchParams.set("category", activeCategory);
      else url.searchParams.delete("category");
      if (query) url.searchParams.set("q", query);
      else url.searchParams.delete("q");
      history.replaceState(null, "", url.toString());
    }

    function applyFilters() {
      var query = searchInput.value.toLowerCase().trim();
      var visibleCount = 0;
      var visibleSet = new Set<string>();

      categoryBtns.forEach(function(b) {
        b.classList.toggle("filter-pill-active", b.dataset.category === activeCategory);
      });
      clearBtn.classList.toggle("!inline-block", !!activeCategory);

      items.forEach(function(item) {
        var mq = !query || item.dataset.term!.includes(query);
        var mc = !activeCategory || (item.dataset.categories || "").split(",").indexOf(activeCategory) !== -1;
        var show = mq && mc;
        item.classList.toggle("hidden", !show);
        if (show) { visibleCount++; visibleSet.add(item.dataset.letter!); }
      });

      jumpBtns.forEach(function(b) {
        b.style.opacity = visibleSet.has(b.dataset.letter!) ? "1" : "0.3";
      });

      var filtering = query || activeCategory;
      countEl.classList.toggle("hidden", !!filtering);
      filteredEl.classList.toggle("hidden", !filtering);
      if (filtering) filteredEl.textContent = visibleCount + " of " + totalItems;
      noResults.classList.toggle("hidden", !(filtering && visibleCount === 0));

      if (filtering) updateUrl();
    }

    categoryBtns.forEach(function(btn) {
      btn.addEventListener("click", function() {
        activeCategory = activeCategory === this.dataset.category! ? "" : this.dataset.category!;
        applyFilters();
      });
    });

    clearBtn.addEventListener("click", function() { activeCategory = ""; applyFilters(); });

    jumpBtns.forEach(function(btn) {
      btn.addEventListener("click", function() {
        var first = document.querySelector<HTMLElement>('.glossary-item[data-letter="' + this.dataset.letter + '"]:not(.hidden)');
        if (first) first.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    searchInput.addEventListener("input", function() {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(applyFilters, 200);
    });

    searchInput.addEventListener("keydown", function(e) {
      if (e.key === "Escape") { searchInput.value = ""; searchInput.blur(); applyFilters(); }
    });

    applyFilters();
  })();
</script>
