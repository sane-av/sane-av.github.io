---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/partials/PageHeader.astro";
import PostSidebar from "@/partials/PostSidebar.astro";
import WhitepaperCard from "@/components/WhitepaperCard.astro";
import Pagination from "@/components/Pagination.astro";
import config from "@/config/config.json";
import { getCollection } from "astro:content";

const SECTION = "whitepapers";
const PAGE_SIZE = config.settings.pagination;

const posts = await getCollection(SECTION, ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0),
);
const totalPages = Math.ceil(posts.length / PAGE_SIZE);
const currentPosts = sortedPosts.slice(0, PAGE_SIZE);

const allTags: string[] = posts.flatMap((p) => p.data.tags).sort((a, b) => a.localeCompare(b));
---

<Base title="Whitepapers" description="Technical writeups and deep dives by SANE editors.">
  <PageHeader title="Whitepapers" />

  <section class="pt-6 pb-4">
    <div class="container text-center">
      <div class="rounded-2xl bg-gradient px-8 py-4">
        <p class="mb-4 text-text-light dark:text-darkmode-text-light">
          Formal technical publications by SANE editors. In-depth analysis and guidance for professional AV practitioners.
        </p>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="/contributing" class="btn btn-primary btn-sm">Contribute &rarr;</a>
          <a href="/feeds" class="btn btn-outline-primary btn-sm">Feeds</a>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-8 pb-24 xl:pt-10 xl:pb-28">
    <div class="container">
      <div class="row gx-5">
        <div class="lg:col-8">
          <div class="row">
            {currentPosts.map((post) => (
              <div class="mb-14 md:col-6" data-tags={(post.data.tags ?? []).join(",")}>
                <WhitepaperCard data={post} />
              </div>
            ))}
          </div>
          <Pagination section={SECTION} currentPage={1} totalPages={totalPages} />
        </div>
        <PostSidebar
          tags={[...new Set(allTags)]}
          basePath="/whitepapers"
        />
      </div>
    </div>
  </section>
</Base>

<script>
  (function() {
    var cards = document.querySelectorAll<HTMLElement>('[data-tags]');
    var clearWrapper = document.getElementById("sidebar-clear-wrapper");
    var clearBtn = document.getElementById("sidebar-clear");
    var activeTag = "";

    function apply() {
      var btns = document.querySelectorAll<HTMLElement>(".filter-tag");
      for (var i = 0; i < btns.length; i++) {
        var match = btns[i].dataset.tag === activeTag;
        btns[i].classList.toggle("!bg-primary/15 !border-primary/50 !text-primary", match);
        btns[i].classList.toggle("dark:!bg-darkmode-primary/15 dark:!border-darkmode-primary/50 dark:!text-darkmode-primary", match);
      }
      for (var j = 0; j < cards.length; j++) {
        var cardTags = (cards[j].dataset.tags || "").split(",");
        var cardMatch = !activeTag || cardTags.indexOf(activeTag) !== -1;
        cards[j].classList.toggle("hidden", !cardMatch);
      }
      if (clearWrapper) clearWrapper.classList.toggle("hidden", !activeTag);
    }

    function onClick(e: Event) {
      var el = e.target as HTMLElement | null;
      while (el && el !== document.body) {
        if (el.classList && el.classList.contains("filter-tag") && el.dataset.tag) {
          e.preventDefault();
          activeTag = activeTag === el.dataset.tag ? "" : el.dataset.tag;
          apply();
          if (activeTag) {
            history.replaceState(null, "", window.location.pathname + "?tag=" + encodeURIComponent(activeTag));
          } else {
            history.replaceState(null, "", window.location.pathname);
          }
          return;
        }
        el = el.parentElement;
      }
    }

    document.addEventListener("click", onClick);

    if (clearBtn) {
      clearBtn.addEventListener("click", function() {
        activeTag = "";
        apply();
        history.replaceState(null, "", window.location.pathname);
      });
    }

    var params = new URLSearchParams(window.location.search);
    var urlTag = params.get("tag");
    if (urlTag) { activeTag = urlTag; apply(); }
  })();
</script>
