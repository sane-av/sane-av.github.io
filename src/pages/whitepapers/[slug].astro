---
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const papers = await getCollection('whitepapers', ({ data }) => !data.draft);
  return papers.map((paper) => ({
    params: { slug: paper.id },
    props: { paper },
  }));
}

const { paper } = Astro.props;
const { Content } = await render(paper);

const dateStr = paper.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<ContentLayout
  title={paper.data.title}
  description={paper.data.description}
  breadcrumb={[{ label: 'Whitepapers', href: '/whitepapers' }]}
>
  <div class="card-meta" style="margin-bottom:1.25rem">
    <time datetime={paper.data.pubDate.toISOString()}>{dateStr}</time>
    <span>By {paper.data.authors.join(', ')}</span>
  </div>
  {paper.data.tags.length > 0 && (
    <div class="card-tags" style="margin-bottom:1.75rem">
      {paper.data.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  )}
  <Content />
</ContentLayout>
