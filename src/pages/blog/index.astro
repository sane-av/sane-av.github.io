---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDateShort } from '../../lib/date';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="Blog" description="Articles, announcements, and deep dives from the SANE community.">
  <div class="page-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Articles, announcements, and deep dives from the SANE community.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {allTags.length > 0 && (
        <div class="flex-wrap mb-2">
          <span class="text-small font-semibold">Tags:</span>
          {allTags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}

      {posts.length === 0 ? (
        <p class="text-muted">No posts yet. <a href="https://github.com/sane-av/sane-av.github.io">Be the first to contribute!</a></p>
      ) : (
        <div class="card-grid">
          {posts.map((post) => (
            <div class="card">
              <div class="card-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDateShort(post.data.pubDate)}
                </time>
                <span>{post.data.author}</span>
              </div>
              <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              <div class="card-tags">
                {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
