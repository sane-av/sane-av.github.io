---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDateShort } from '../../lib/date';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="Blog" description="Articles, announcements, and deep dives from the SANE community.">
  <div class="page-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Articles, announcements, and deep dives from the SANE community.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {allTags.length > 0 && (
        <div class="tag-bar" id="tag-bar">
          {allTags.map((tag) => (
            <button type="button" class="tag filter-tag" data-tag={tag}>{tag}</button>
          ))}
        </div>
      )}

      <p id="post-count" class="text-muted mb-1">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>

      {posts.length === 0 ? (
        <p class="text-muted">No posts yet. <a href="https://github.com/sane-av/sane-av.github.io">Be the first to contribute!</a></p>
      ) : (
        <div class="card-grid" id="card-grid">
          {posts.map((post) => (
            <div class="card" data-tags={post.data.tags.join(',')}>
              <div class="card-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDateShort(post.data.pubDate)}
                </time>
                <span>{post.data.author}</span>
              </div>
              <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
              <div class="card-tags">
                {post.data.tags.map((tag) => <button type="button" class="tag filter-tag" data-tag={tag}>{tag}</button>)}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const tagButtons = document.querySelectorAll<HTMLButtonElement>('.filter-tag');
  const cards = document.querySelectorAll<HTMLDivElement>('#card-grid .card');
  const countEl = document.getElementById('post-count')!;
  const totalCount = cards.length;

  let activeTag = '';

  function applyFilters() {
    let visible = 0;
    tagButtons.forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.tag === activeTag);
    });
    cards.forEach((card) => {
      const cardTags = (card.dataset.tags || '').split(',');
      const match = !activeTag || cardTags.includes(activeTag);
      (card as HTMLElement).style.display = match ? '' : 'none';
      if (match) visible++;
    });
    const filtering = !!activeTag;
    countEl.textContent = filtering
      ? `${visible} of ${totalCount} post${totalCount !== 1 ? 's' : ''}`
      : `${totalCount} post${totalCount !== 1 ? 's' : ''}`;
  }

  tagButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;
      activeTag = activeTag === tag ? '' : tag;
      applyFilters();
    });
  });

  const params = new URLSearchParams(window.location.search);
  const urlTag = params.get('tag');
  if (urlTag) {
    activeTag = urlTag;
    applyFilters();
  }
</script>
