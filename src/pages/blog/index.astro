---
import BlogCard from "@/components/BlogCard.astro";
import Pagination from "@/components/Pagination.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getCollection } from "astro:content";
import PageHeader from "@/partials/PageHeader.astro";
import PostSidebar from "@/partials/PostSidebar.astro";

const BLOG_FOLDER = "blog";
const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0),
);
const totalPages = Math.ceil(posts.length / config.settings.pagination);
const currentPosts = sortedPosts.slice(0, config.settings.pagination);

const allTags: string[] = posts.flatMap((p) => p.data.tags).sort((a, b) => a.localeCompare(b));
---

<Base title="Blog" description="Perspectives, announcements, and deep dives from the SANE community.">
  <PageHeader title="Blog" />

  <section class="pt-6 pb-4">
    <div class="container text-center">
      <div class="rounded-2xl bg-gradient px-8 py-4">
        <p class="mb-4 text-text-light dark:text-darkmode-text-light">
          Perspectives, announcements, and deep dives from the SANE community.
        </p>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="/contributing" class="btn btn-primary btn-sm">Contribute &rarr;</a>
          <a href="/feeds" class="btn btn-outline-primary btn-sm">Feeds</a>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-8 pb-24 xl:pt-10 xl:pb-28">
    <div class="container">
      <div class="row gx-5">
        <div class="lg:col-8">
          <div class="row">
            {currentPosts.map((post) => (
              <div class="mb-14 md:col-6" data-tags={(post.data.tags ?? []).join(",")}>
                <BlogCard data={post} />
              </div>
            ))}
          </div>
          <Pagination section={BLOG_FOLDER} currentPage={1} totalPages={totalPages} />
        </div>
        <PostSidebar
          tags={[...new Set(allTags)]}
        />
      </div>
    </div>
  </section>
</Base>

<script>
  var cards = document.querySelectorAll<HTMLElement>('[data-tags]');
  var clearWrapper = document.getElementById("sidebar-clear-wrapper");
  var clearBtn = document.getElementById("sidebar-clear");
  var activeTag = "";

  function apply() {
    document.querySelectorAll<HTMLElement>(".filter-tag").forEach(function(btn) {
      var match = btn.dataset.tag === activeTag;
      btn.classList.toggle("!bg-primary/15 !border-primary/50 !text-primary", match);
      btn.classList.toggle("dark:!bg-darkmode-primary/15 dark:!border-darkmode-primary/50 dark:!text-darkmode-primary", match);
    });
    cards.forEach(function(card) {
      var cardTags = (card.dataset.tags || "").split(",");
      var match = !activeTag || cardTags.includes(activeTag);
      card.classList.toggle("hidden", !match);
    });
    if (clearWrapper) clearWrapper.classList.toggle("hidden", !activeTag);
  }

  document.addEventListener("click", function(e) {
    var btn = (e.target as HTMLElement).closest(".filter-tag") as HTMLButtonElement | null;
    if (!btn || !btn.dataset.tag) return;
    activeTag = activeTag === btn.dataset.tag ? "" : btn.dataset.tag;
    apply();
    if (activeTag) {
      history.replaceState(null, "", window.location.pathname + "?tag=" + encodeURIComponent(activeTag));
    } else {
      history.replaceState(null, "", window.location.pathname);
    }
  });

  if (clearBtn) {
    clearBtn.addEventListener("click", function() { activeTag = ""; apply(); history.replaceState(null, "", window.location.pathname); });
  }

  var params = new URLSearchParams(window.location.search);
  var urlTag = params.get("tag");
  if (urlTag) { activeTag = urlTag; apply(); }
</script>
