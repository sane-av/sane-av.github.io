{
  "site": {
    "title": "SANE",
    "base_url": "https://sane-av.github.io",
    "base_path": "/",
    "trailing_slash": false,
    "favicon": "/images/SANE_Brain.svg",
    "logo": "/images/SANE_Brain.svg",
    "logo_darkmode": "/images/SANE_Brain.svg",
    "logo_width": "48",
    "logo_height": "48",
    "logo_text": "Society for AV Norms & Engineering"
  },

  "settings": {
    "search": true,
    "sticky_header": true,
    "theme_switcher": false,
    "default_theme": "dark",
    "pagination": 4,
    "summary_length": 200,
    "blog_folder": "blog",
    "whitepapers_folder": "whitepapers",
    "content_repos": {
      "blog": "https://github.com/sane-av/sane-av-blog.git",
      "equipment": { "url": "https://github.com/sane-av/sane-av-equipment-list.git", "target": "src/data/equipment" },
      "glossary": "https://github.com/sane-av/sane-av-glossary.git",
      "standards": "https://github.com/sane-av/sane-av-standards.git",
      "whitepapers": "https://github.com/sane-av/sane-av-whitepapers.git"
    }
  },

  "announcement": {
    "enable": false,
    "content": "",
    "expire_days": 7
  },

  "params": {
    "contact_form_action": "#",
    "copyright": "[SANE Contributors](https://github.com/sane-av). Code: [Apache 2.0](https://github.com/sane-av/sane-av.github.io/blob/main/LICENSE) · Content: [CC BY-SA 4.0](https://creativecommons.org/licenses/by-sa/4.0/)"
  },

  "navigation_button": {
    "enable": false,
    "label": "GitHub",
    "link": "https://github.com/sane-av/sane-av.github.io"
  },

  "metadata": {
    "meta_author": "SANE Contributors",
    "meta_image": "/images/SANE_Brain.svg",
    "meta_description": "SANE - Society for AV Norms & Engineering. Open source AV standards, data, and tools for the professional audiovisual industry."
  },

  "llms": {
    "generate_llms_txt": true,
    "generate_llms_full_txt": true,
    "generate_individual_md": true,
    "include": [],
    "exclude": []
  }
}
