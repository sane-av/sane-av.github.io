---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'SANE - Society for AV Norms & Engineering. Open source AV standards, data, and tools.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | SANE - Society for AV Norms & Engineering</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <slot name="header">
      <header class="site-header">
        <div class="container">
          <a href="/" class="site-logo">
            <img class="logo-badge" src="/sanebrainonly.png" alt="SANE" width="48" height="48" />
            <span class="site-logo-text">Society for AV Norms &amp; Engineering</span>
          </a>
          <nav class="site-nav" aria-label="Main navigation">
            <a href="/standards">Standards</a>
            <a href="/glossary">Glossary</a>
            <a href="/blog">Blog</a>
            <div class="nav-dropdown">
              <button class="nav-dropdown-trigger" aria-haspopup="true" aria-expanded="false">Resources</button>
              <div class="nav-dropdown-menu">
                <a href="/whitepapers">Whitepapers</a>
                <a href="/equipment">Equipment DB</a>
                <a href="/tools">Tools &amp; Calculators</a>
                <a href="/rfc">RFCs</a>
              </div>
            </div>
            <a href="/contributing">Contributing</a>
          </nav>
        </div>
      </header>
    </slot>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-col">
            <h4>SANE</h4>
            <p class="footer-desc">
              Open source AV standards, data, and engineering resources for the pro AV community.
            </p>
          </div>
          <div class="footer-col">
            <h4>Standards</h4>
            <ul>
              <li><a href="/standards">All Standards</a></li>
              <li><a href="/rfc">Propose a Standard (RFC)</a></li>
              <li><a href="/whitepapers">Whitepapers</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Resources</h4>
            <ul>
              <li><a href="/glossary">Glossary</a></li>
              <li><a href="/equipment">Equipment DB</a></li>
              <li><a href="/tools">Calculators</a></li>
              <li><a href="/blog">Blog</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Community</h4>
            <ul>
              <li><a href="https://github.com/sane-av" target="_blank" rel="noopener">GitHub</a></li>
              <li><a href="https://github.com/sane-av/sane-av.github.io/discussions" target="_blank" rel="noopener">Discussions</a></li>
              <li><a href="https://github.com/sane-av/sane-av.github.io/issues" target="_blank" rel="noopener">Issues / RFCs</a></li>
              <li><a href="/contributing">Contributing</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span>
            &copy; {new Date().getFullYear()} SANE Contributors.
            Code: <a href="https://github.com/sane-av/sane-av.github.io/blob/main/LICENSE">MIT</a> &bull;
            Content: <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY 4.0</a>
          </span>
          <span>
            <a href="https://github.com/sane-av/sane-av.github.io" target="_blank" rel="noopener">
              View on GitHub
            </a>
          </span>
        </div>
      </div>
    </footer>
    <button class="back-to-top" id="back-to-top" aria-label="Back to top" title="Back to top">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M10 16V4M4 10l6-6 6 6"/>
      </svg>
    </button>
  </body>
  <script>
    // Touch-friendly dropdown toggle
    document.querySelectorAll('.nav-dropdown-trigger').forEach(btn => {
      btn.addEventListener('click', function(this: HTMLButtonElement, e: MouseEvent) {
        const dd = this.closest('.nav-dropdown');
        const isOpen = dd?.classList.toggle('open');
        this.setAttribute('aria-expanded', String(!!isOpen));
      });
    });

    // Back to top button
    const btt = document.getElementById('back-to-top');
    if (btt) {
      window.addEventListener('scroll', () => {
        btt.classList.toggle('visible', window.scrollY > 400);
      });
      btt.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  </script>
</html>
