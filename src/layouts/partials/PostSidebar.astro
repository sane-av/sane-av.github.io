---
import { humanize } from "@/lib/utils/textConverter";

const { tags, categories } = Astro.props;
---

<div class="lg:col-4">
  {categories && categories.length > 0 && (
    <div class="mb-8">
      <h5 class="mb-6">Categories</h5>
      <div class="rounded bg-light p-8 dark:bg-darkmode-light">
        <ul class="space-y-4">
          {
            categories.map((category: any) => {
              return (
                <li>
                  <a
                    class="flex justify-between hover:text-primary dark:hover:text-darkmode-primary"
                    href={`/categories/${category}`}
                  >
                    {humanize(category)}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>
    </div>
  )}
  {tags && tags.length > 0 && (
    <div class="mb-8">
      <h5 class="mb-6">Tags</h5>
      <div class="rounded bg-light p-6 dark:bg-darkmode-light">
        <div class="flex flex-wrap gap-1" id="sidebar-tags">
          {
            tags.map((tag: any) => {
              return (
                <a
                  href={`?tag=${encodeURIComponent(tag)}`}
                  class="tag-pill"
                  data-tag={tag}
                >
                  {humanize(tag)}
                </a>
              );
            })
          }
        </div>
        <button id="sidebar-clear" onclick="window.location.href=window.location.pathname" class="mt-3 hidden w-full rounded bg-light px-3 py-1 text-xs text-text-light hover:text-primary dark:bg-darkmode-body dark:text-darkmode-text-light dark:hover:text-darkmode-primary transition-colors">
          Clear filter
        </button>
      </div>
    </div>
  )}
</div>
