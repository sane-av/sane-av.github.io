---
interface Props {
  name: string;
  date: string;
  score: number;
  total: number;
  certName: string;
}

const { name, date, score, total, certName } = Astro.props;
const percentage = Math.round((score / total) * 100);
const svgWidth = 800;
const svgHeight = 600;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={`0 0 ${svgWidth} ${svgHeight}`}
  width="100%"
  height="auto"
  style="max-width: 800px; border: 1px solid #e5e7eb;"
>
  <defs>
    <linearGradient id="certBorder" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#3b82f6" />
      <stop offset="50%" stop-color="#8b5cf6" />
      <stop offset="100%" stop-color="#3b82f6" />
    </linearGradient>
  </defs>

  <rect x="0" y="0" width={svgWidth} height={svgHeight} fill="#0f172a" />

  <rect x="20" y="20" width={svgWidth - 40} height={svgHeight - 40} fill="none" stroke="url(#certBorder)" stroke-width="3" rx="8" />

  <rect x="35" y="35" width={svgWidth - 70} height={svgHeight - 70} fill="none" stroke="url(#certBorder)" stroke-width="1" stroke-dasharray="6 4" rx="4" />

  <text x={svgWidth / 2} y="100" text-anchor="middle" fill="#3b82f6" font-family="monospace" font-size="18" font-weight="bold">SOCIETY FOR AV NORMS &amp; ENGINEERING</text>

  <text x={svgWidth / 2} y="160" text-anchor="middle" fill="#e2e8f0" font-family="sans-serif" font-size="28" font-weight="bold">Certificate of Completion</text>

  <text x={svgWidth / 2} y="210" text-anchor="middle" fill="#94a3b8" font-family="sans-serif" font-size="16">This certifies that</text>

  <text x={svgWidth / 2} y="280" text-anchor="middle" fill="#f8fafc" font-family="sans-serif" font-size="36" font-weight="bold">{name}</text>

  <line x1="200" y1="300" x2={svgWidth - 200} y2="300" stroke="#334155" stroke-width="1" />

  <text x={svgWidth / 2} y="360" text-anchor="middle" fill="#94a3b8" font-family="sans-serif" font-size="16">has successfully completed the</text>

  <text x={svgWidth / 2} y="410" text-anchor="middle" fill="#f8fafc" font-family="sans-serif" font-size="24" font-weight="bold">{certName}</text>

  <text x={svgWidth / 2} y="460" text-anchor="middle" fill="#94a3b8" font-family="sans-serif" font-size="16">with a score of {percentage}% ({score} / {total})</text>

  <text x={svgWidth / 2} y="520" text-anchor="middle" fill="#64748b" font-family="sans-serif" font-size="14">Date: {date}</text>

  <text x={svgWidth / 2} y="560" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="11">This certificate is awarded as part of SANE's community education program.</text>
  <text x={svgWidth / 2} y="576" text-anchor="middle" fill="#475569" font-family="sans-serif" font-size="11">sane-av.org/certifications</text>
</svg>
