:---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

// Props interface for the component
interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  loading?: "eager" | "lazy" | null | undefined;
  decoding?: "async" | "auto" | "sync" | null | undefined;
  format?: "auto" | "avif" | "jpeg" | "png" | "svg" | "webp";
  class?: string;
  style?: string;
}

// Destructuring Astro.props to get the component's props
const {
  src,
  alt,
  width,
  height,
  loading,
  decoding,
  class: className,
  format,
  style,
} = Astro.props;

const imagePath = `/public${src}`;

// Glob pattern to load images from the /public/images folder
const images = import.meta.glob("/public/images/**/*.{jpeg,jpg,png,gif,svg}");

// Check if the source path is valid
const isValidPath = imagePath in images;

// Log a warning message in red if the image is not found
if (!isValidPath) {
  console.error(
    `\x1b[31mImage not found - ${imagePath}.\x1b[0m Make sure the image is in the /public/images folder.`,
  );
}
---

{
  isValidPath && (
    <Image
      src={images[imagePath]() as Promise<{ default: ImageMetadata }>}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      class={className}
      format={format}
      style={style}
    />
  )
}
