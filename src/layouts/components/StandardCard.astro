---
import dateFormat from "@/lib/utils/dateFormat";
import { statusColors, statusDescriptions } from "@/lib/statusColors";

const { data } = Astro.props;
const entry = data.data;
const visibleTagCount = 3;
const extraTagCount = Math.max(0, entry.tags.length - visibleTagCount);
const sortedTags = entry.tags.sort((a: string, b: string) => a.localeCompare(b));
const cardId = `card-${entry.saneId}`;
---

<div class="content-card" id={cardId}>
  <div class="mb-3">
    <span class={`inline-block rounded-full px-2.5 py-0.5 text-[11px] font-medium uppercase tracking-wide ${statusColors[entry.status] || ""}`} title={statusDescriptions[entry.status] ?? ""}>
      {entry.status}
    </span>
  </div>

  <a href={`/standards/${data.id}`} class="card-title" style="text-decoration: none">
    {entry.title}
  </a>

  <div class="card-meta">
    <span class="font-mono font-semibold tracking-tight text-primary dark:text-darkmode-primary">{entry.saneId}</span>
    <span class="meta-sep">&middot;</span>
    <span class="text-text-light dark:text-darkmode-text-light">v{entry.version}</span>
    <span class="meta-sep">&middot;</span>
    <span class="text-text-light dark:text-darkmode-text-light">{dateFormat(entry.pubDate, "d MMM yyyy")}</span>
  </div>

  <p class="card-desc line-clamp-3">{entry.description}</p>

  <div class="card-tags" id={`${cardId}-tags`}>
    {sortedTags.slice(0, visibleTagCount).map((tag: string) => (
      <button type="button" class="tag-pill filter-tag" data-tag={tag}>
        {tag}
      </button>
    ))}
    {extraTagCount > 0 && (
      <button type="button" class="tag-pill" data-expand={cardId} data-extra-tags={sortedTags.slice(visibleTagCount).join(",")}>
        +{extraTagCount}
      </button>
    )}
  </div>

  <a href={`/standards/${data.id}`} class="card-link">Read standard <span aria-hidden="true">&rarr;</span></a>
</div>

{extraTagCount > 0 && (
  <script>
    (function() {
      var btn = document.querySelector('[data-expand="{cardId}"]')!;
      var tagContainer = document.getElementById("{cardId}-tags")!;
      var extraTags = btn.getAttribute("data-extra-tags")?.split(",") ?? [];
      btn.addEventListener("click", function() {
        extraTags.forEach(function(tag) {
          var tagBtn = document.createElement("button");
          tagBtn.type = "button";
          tagBtn.className = "tag-pill filter-tag";
          tagBtn.dataset.tag = tag;
          tagBtn.textContent = tag;
          tagContainer.insertBefore(tagBtn, btn);
        });
        btn.remove();
      });
    })();
  </script>
)}
