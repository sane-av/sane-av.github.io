---
import dateFormat from "@/lib/utils/dateFormat";
import { statusColors, statusDescriptions } from "@/lib/statusColors";

const { data } = Astro.props;
const entry = data.data;
const sortedTags = [...entry.tags].sort((a: string, b: string) => a.localeCompare(b));
const VISIBLE = 3;
const hiddenTags = sortedTags.slice(VISIBLE);
const extraTagCount = hiddenTags.length;
const basePath = "/standards";
---

<div class="content-card">
  <div class="mb-3">
    <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-medium uppercase tracking-wide ${statusColors[entry.status] || ""}`} title={statusDescriptions[entry.status] ?? ""}>
      {entry.status}
    </span>
  </div>

  <a href={`/standards/${data.id}`} class="card-title" style="text-decoration: none">
    {entry.title}
  </a>

  <div class="card-meta">
    <span class="font-mono font-semibold tracking-tight text-primary dark:text-darkmode-primary">{entry.saneId}</span>
    <span class="meta-sep">&middot;</span>
    <span class="text-text-light dark:text-darkmode-text-light">v{entry.version}</span>
    <span class="meta-sep">&middot;</span>
    <span class="text-text-light dark:text-darkmode-text-light">{dateFormat(entry.pubDate, "d MMM yyyy")}</span>
  </div>

  <p class="card-desc line-clamp-3">{entry.description}</p>

  <a href={`/standards/${data.id}`} class="card-link">Read standard <span aria-hidden="true">&rarr;</span></a>

  {sortedTags.length > 0 && (
    <div class="card-tags">
      {sortedTags.slice(0, VISIBLE).map((tag: string) => (
        <a href={`${basePath}?tag=${encodeURIComponent(tag)}`} class="tag-pill">
          {tag}
        </a>
      ))}
      {extraTagCount > 0 && (
        <button type="button" class="tag-pill" data-hidden={JSON.stringify(hiddenTags)} data-base={basePath} onclick="var s=this,h=JSON.parse(s.dataset.hidden),b=s.dataset.base,p=s.parentElement;h.forEach(function(t){var a=document.createElement('a');a.href=b+'?tag='+encodeURIComponent(t);a.className='tag-pill';a.textContent=t;p.insertBefore(a,s)});s.remove()">
          +{extraTagCount}
        </button>
      )}
    </div>
  )}
</div>
