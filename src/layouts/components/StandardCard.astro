---
import dateFormat from "@/lib/utils/dateFormat";
import { statusColors } from "@/lib/statusColors";

const { data } = Astro.props;
const entry = data.data;
const visibleTagCount = 3;
const extraTagCount = Math.max(0, entry.tags.length - visibleTagCount);
const sortedTags = entry.tags.sort((a: string, b: string) => a.localeCompare(b));
const cardId = `card-${entry.saneId}`;
---

<div class="h-full flex flex-col rounded-lg border border-border p-6 dark:border-darkmode-border bg-body dark:bg-darkmode-body" data-tags={entry.tags.join(",")} id={cardId}>
  <h4 class="mb-3">
    <a href={`/standards/${data.id}`}>{entry.title}</a>
  </h4>

  <div class="mb-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
    <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${statusColors[entry.status] || ""}`}>
      {entry.status}
    </span>
    <span class="font-mono font-bold text-text-dark dark:text-darkmode-text-dark">{entry.saneId}</span>
    <span class="text-text-light dark:text-darkmode-text-light">v{entry.version}</span>
    <span class="text-text-light dark:text-darkmode-text-light">{dateFormat(entry.pubDate, "d MMM yyyy")}</span>
  </div>

  <p class="grow mb-6 line-clamp-4 overflow-hidden text-text-light dark:text-darkmode-text-light">{entry.description}</p>

  <div class="mb-6 flex flex-wrap gap-1" id={`${cardId}-tags`}>
    {sortedTags.slice(0, visibleTagCount).map((tag: string) => (
      <button type="button" class="filter-tag rounded bg-light px-2 py-0.5 text-xs underline decoration-text-light/50 underline-offset-2 hover:bg-primary hover:text-white dark:bg-darkmode-body dark:decoration-darkmode-primary/40 dark:hover:bg-darkmode-primary dark:hover:text-text-dark" data-tag={tag}>
        #{tag}
      </button>
    ))}
    {extraTagCount > 0 && (
      <button type="button" class="rounded bg-light px-2 py-0.5 text-xs underline decoration-text-light/50 underline-offset-2 hover:bg-primary hover:text-white dark:bg-darkmode-body dark:decoration-darkmode-primary/40 dark:hover:bg-darkmode-primary dark:hover:text-text-dark" data-expand={cardId} data-extra-tags={sortedTags.slice(visibleTagCount).join(",")}>
        +{extraTagCount} more
      </button>
    )}
  </div>

  <a class="btn btn-outline-primary btn-sm mt-auto" href={`/standards/${data.id}`}>Read More</a>
</div>

{extraTagCount > 0 && (
  <script>
    (function() {
      var btn = document.querySelector('[data-expand="{cardId}"]')!;
      var tagContainer = document.getElementById("{cardId}-tags")!;
      var extraTags = btn?.getAttribute("data-extra-tags")?.split(",") ?? [];
      btn.addEventListener("click", function() {
        extraTags.forEach(function(tag) {
          var tagBtn = document.createElement("button");
          tagBtn.type = "button";
          tagBtn.className = "filter-tag rounded bg-light px-2 py-0.5 text-xs underline decoration-text-light/50 underline-offset-2 hover:bg-primary hover:text-white dark:bg-darkmode-body dark:decoration-darkmode-primary/40 dark:hover:bg-darkmode-primary dark:hover:text-text-dark";
          tagBtn.dataset.tag = tag;
          tagBtn.textContent = "#" + tag;
          tagContainer.insertBefore(tagBtn, btn);
        });
        btn.remove();
      });
    })();
  </script>
)}
