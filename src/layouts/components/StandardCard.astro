---
import dateFormat from "@/lib/utils/dateFormat";
import { statusColors } from "@/lib/statusColors";

const { data } = Astro.props;
const entry = data.data;
---

<div class="h-full flex flex-col rounded-lg border border-border p-6 dark:border-darkmode-border bg-body dark:bg-darkmode-body" data-tags={entry.tags.join(",")}>
  <h4 class="mb-3">
    <a href={`/standards/${data.id}`}>{entry.title}</a>
  </h4>
  <ul class="mb-4">
    <li class="mr-4 inline-block">
      <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${statusColors[entry.status] || ""}`}>
        {entry.status}
      </span>
    </li>
    <li class="mr-4 inline-block">
      <span class="font-mono font-bold text-text-dark dark:text-darkmode-text-dark">{entry.saneId}</span>
    </li>
    <li class="mr-4 inline-block text-text-light dark:text-darkmode-text-light">
      v{entry.version}
    </li>
    <li class="mr-4 inline-block text-text-light dark:text-darkmode-text-light">
      {dateFormat(entry.pubDate)}
    </li>
  </ul>
  <p class="grow mb-6 line-clamp-4 overflow-hidden text-text-light dark:text-darkmode-text-light">{entry.description}</p>
  <div class="mb-6 flex flex-wrap gap-1">
    {entry.tags.sort((a, b) => a.localeCompare(b)).map((tag: string) => (
      <button type="button" class="filter-tag rounded bg-light px-2 py-0.5 text-xs underline decoration-text-light/50 underline-offset-2 hover:bg-primary hover:text-white dark:bg-darkmode-body dark:decoration-darkmode-primary/40 dark:hover:bg-darkmode-primary dark:hover:text-text-dark" data-tag={tag}>
        #{tag}
      </button>
    ))}
  </div>
  <a class="btn btn-outline-primary btn-sm mt-auto" href={`/standards/${data.id}`}>Read More</a>
</div>
