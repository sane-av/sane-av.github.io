---
import config from "@/config/config.json";
import dateFormat from "@/lib/utils/dateFormat";
import { plainify, slugify } from "@/lib/utils/textConverter";
import { FaRegUserCircle } from "react-icons/fa";
import ImageMod from "./ImageMod.astro";

const { summary_length, blog_folder } = config.settings;
const { data } = Astro.props;
const entry = data.data;

const title = entry.title;
const image = entry.image;
const pubDate = entry.pubDate ?? entry.date;
const author = entry.authors?.[0] ?? entry.author ?? "SANE";
const tags = entry.tags ?? [];
const visibleTagCount = 3;
const extraTagCount = Math.max(0, tags.length - visibleTagCount);
const sortedTags = [...tags].sort((a: string, b: string) => a.localeCompare(b));
const cardId = `blog-${data.id.replace(/\//g, "-")}`;
---

<div class="h-full flex flex-col rounded-lg border border-border p-6 dark:border-darkmode-border bg-body dark:bg-darkmode-body">
  {image && (
    <ImageMod class="mb-6 w-full rounded" src={image} alt={title} width={445} height={230} format="webp" />
  )}
  <h4 class="mb-3">
    <a href={`/${blog_folder}/${data.id}`}>{title}</a>
  </h4>

  <div class="card-meta">
    <a href={`/authors/${slugify(author)}`} class="inline-flex items-center gap-1.5 text-xs text-text-dark dark:text-darkmode-text-dark hover:text-primary dark:hover:text-darkmode-primary transition-colors">
      <FaRegUserCircle className="text-sm" />
      {author}
    </a>
    {pubDate && (
      <>
        <span class="meta-sep">&middot;</span>
        <span class="text-xs text-text-light dark:text-darkmode-text-light">{dateFormat(pubDate, "d MMM yyyy")}</span>
      </>
    )}
  </div>

  <p class="grow mb-6 line-clamp-4 overflow-hidden text-text-light dark:text-darkmode-text-light">{plainify(data.body?.slice(0, Number(summary_length)) || entry.description?.slice(0, Number(summary_length)) || "")}</p>

  <div class="mb-6 flex flex-wrap gap-1" id={`${cardId}-tags`}>
    {sortedTags.slice(0, visibleTagCount).map((tag: string) => (
      <a href={`/blog/?tag=${tag}`} class="tag-pill">
        #{tag}
      </a>
    ))}
    {extraTagCount > 0 && (
      <button type="button" class="tag-pill" data-expand={cardId} data-extra-tags={sortedTags.slice(visibleTagCount).join(",")}>
        +{extraTagCount} more
      </button>
    )}
  </div>

  <a class="btn btn-outline-primary btn-sm mt-auto" href={`/${blog_folder}/${data.id}`}>Read More</a>
</div>

{extraTagCount > 0 && (
  <script>
    (function() {
      var btn = document.querySelector('[data-expand="{cardId}"]')!;
      var tagContainer = document.getElementById("{cardId}-tags")!;
      var extraTags = btn.getAttribute("data-extra-tags")?.split(",") ?? [];
      btn.addEventListener("click", function() {
        extraTags.forEach(function(tag) {
          var tagBtn = document.createElement("a");
          tagBtn.href = "/blog/?tag=" + encodeURIComponent(tag);
          tagBtn.className = "tag-pill";
          tagBtn.textContent = "#" + tag;
          tagContainer.insertBefore(tagBtn, btn);
        });
        btn.remove();
      });
    })();
  </script>
)}
