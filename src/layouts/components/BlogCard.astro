---
import config from "@/config/config.json";
import dateFormat from "@/lib/utils/dateFormat";
import { plainify, slugify } from "@/lib/utils/textConverter";
import { FaRegUserCircle } from "react-icons/fa";
import ImageMod from "./ImageMod.astro";

const { summary_length, blog_folder } = config.settings;
const { data } = Astro.props;
const entry = data.data;

const title = entry.title;
const image = entry.image;
const pubDate = entry.pubDate ?? entry.date;
const author = entry.authors?.[0] ?? entry.author ?? "SANE";
const tags = entry.tags ?? [];
const sortedTags = [...tags].sort((a: string, b: string) => a.localeCompare(b));
const VISIBLE = 3;
const hiddenTags = sortedTags.slice(VISIBLE);
const extraTagCount = hiddenTags.length;
const basePath = `/${blog_folder}`;
---

<div class="content-card">
  {image && (
    <ImageMod class="mb-4 w-full rounded-lg" src={image} alt={title} width={445} height={230} format="webp" />
  )}

  <a href={`/${blog_folder}/${data.id}`} class="card-title" style="text-decoration: none">
    {title}
  </a>

  <div class="card-meta">
    <a href={`/authors/${slugify(author)}`} class="meta-author">
      <FaRegUserCircle className="text-[13px]" />
      {author}
    </a>
    {pubDate && (
      <>
        <span class="meta-sep">&middot;</span>
        <span class="text-text-light dark:text-darkmode-text-light">{dateFormat(pubDate, "d MMM yyyy")}</span>
      </>
    )}
  </div>

  <p class="card-desc">{plainify(data.body?.slice(0, Number(summary_length)) || entry.description?.slice(0, Number(summary_length)) || "")}</p>

  <a href={`/${blog_folder}/${data.id}`} class="card-link">Read post <span aria-hidden="true">&rarr;</span></a>

  {sortedTags.length > 0 && (
    <div class="card-tags">
      {sortedTags.slice(0, VISIBLE).map((tag: string) => (
        <a href={`${basePath}?tag=${encodeURIComponent(tag)}`} class="tag-pill">
          {tag}
        </a>
      ))}
      {extraTagCount > 0 && (
        <button type="button" class="tag-pill" data-hidden={JSON.stringify(hiddenTags)} data-base={basePath} onclick="var h=JSON.parse(this.dataset.hidden),b=this.dataset.base,p=this.parentElement;h.forEach(function(t){var a=document.createElement('a');a.href=b+'?tag='+encodeURIComponent(t);a.className='tag-pill';a.textContent=t;p.insertBefore(a,this)});this.remove()">
          +{extraTagCount}
        </button>
      )}
    </div>
  )}
</div>
