{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "meta_title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "image": {
      "type": "string"
    },
    "draft": {
      "type": "boolean"
    },
    "social": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "link": {
            "type": "string"
          }
        }
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description"
  ]
}