              "type": "string"
            }
          },
          "button": {
            "type": "object",
            "properties": {
              "enable": {
                "type": "boolean"
              },
              "label": {
                "type": "string"
              },
              "link": {
                "type": "string"
              }
            },
            "required": [
              "enable",
              "label",
              "link"
            ]
          }
        },
        "required": [
          "title",
          "image",
          "content",
          "bulletpoints",
          "button"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "banner",
    "features"
  ]
}